---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProfileSelector from '../../components/ProfileSelector.astro';
---

<Layout title="Development Projects - Noor Azami" description="Software development projects including web apps, mobile applications, and full-stack systems showcasing technical expertise." canonical="/role-software-developer/projects">
    <Header />
    <ProfileSelector />
    <main class="pt-16">
        <section class="py-24 px-4 sm:px-6 lg:px-8 text-center">
            <div class="container mx-auto fade-in-scroll">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">Development Projects</h1>
                <p class="text-lg text-text-secondary max-w-3xl mx-auto">A collection of full-stack applications, mobile apps, and web development projects showcasing technical skills and creative problem-solving.</p>
            </div>
        </section>

        <section class="pb-24 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto max-w-6xl">
                <!-- Filter Counter -->
                <div class="flex flex-col items-center mb-12 fade-in-scroll">
                    <div class="filter-counter text-lg font-semibold">4 Development Projects</div>
                </div>

                <!-- Project Grid -->
                <div class="projects-grid project-grid">
                    <!-- Project: StyleHub -->
                    <div class="project-card fade-in-scroll" data-category="web-development">
                        <div class="project-image-container">
                            <img src={import.meta.env.BASE_URL + "assets/stylehub.png"} alt="StyleHub Fashion E-Commerce Store" class="w-full h-full object-cover rounded-lg" width="368" height="178" loading="lazy">
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">StyleHub - Fashion E-Commerce Platform</h3>
                                <div class="project-badges">
                                    <span class="project-badge web-development">Web Development</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">React</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Node.js</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">PostgreSQL</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A modern, responsive e-commerce website built with React, Node.js, and PostgreSQL. Features complete shopping experience with user authentication, product management, shopping cart, order processing, and administrative dashboard.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/stylehub"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Rumah Tenang -->
                    <div class="project-card fade-in-scroll" data-category="web-development">
                        <div class="project-image-container">
                            <img src={import.meta.env.BASE_URL + "assets/rumah_tenang.webp"} alt="Rumah Tenang Project" class="w-full h-full object-contain rounded-lg" width="368" height="178" loading="lazy">
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Rumah Tenang - Hotel Management System</h3>
                                <div class="project-badges">
                                    <span class="project-badge web-development">Web Development</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">HTML/CSS</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">JavaScript</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Database</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A comprehensive hotel management system featuring responsive design for both guests and administrators. Includes booking system, room management, guest tracking, and administrative analytics dashboard.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/rumah-tenang"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Nasi Lemak Burger -->
                    <div class="project-card fade-in-scroll" data-category="mobile">
                        <div class="project-image-container">
                            <img src={import.meta.env.BASE_URL + "assets/burger.webp"} alt="Nasi Lemak Burger Food Delivery App" class="w-full h-full object-cover rounded-lg" width="368" height="178" loading="lazy">
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Nasi Lemak Burger - Food Delivery App</h3>
                                <div class="project-badges">
                                    <span class="project-badge mobile">Mobile App</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">Flutter</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Firebase</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">Maps API</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">Cross-platform mobile food delivery application built with Flutter. Features real-time order tracking, integrated maps, payment processing, restaurant management, and user reviews system.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/nasi-lemak-burger"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Healthy Food App -->
                    <div class="project-card fade-in-scroll" data-category="mobile">
                        <div class="project-image-container">
                            <div class="w-full h-full bg-gradient-to-br from-green-500/20 to-emerald-500/20 rounded-lg flex items-center justify-center border border-green-500/30">
                                <div class="text-center">
                                    <div class="w-16 h-16 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                                        </svg>
                                    </div>
                                    <h4 class="text-sm font-bold text-green-400">Healthy Food</h4>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Healthy Food App - Nutrition Tracker</h3>
                                <div class="project-badges">
                                    <span class="project-badge mobile">Mobile App</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">Flutter</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">REST API</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">SQLite</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">Mobile application for nutrition tracking and meal planning. Features include calorie counting, meal suggestions, nutrition analysis, workout tracking, and personalized health recommendations.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/healthy-food-app"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-24 px-4 sm:px-6 lg:px-8 bg-accent-color text-center">
            <div class="container mx-auto max-w-4xl fade-in-scroll">
                <h2 class="text-4xl font-bold mb-6">Full-Stack Development Expertise</h2>
                <p class="text-lg text-text-secondary mb-8">From web applications to mobile apps, these projects demonstrate proficiency in modern development technologies and creative problem-solving</p>
                <a href="/portfolio/role-software-developer/" class="button_primary text-lg font-bold px-8 py-3">
                    Back to Developer Profile
                </a>
            </div>
        </section>
    </main>
</Layout>

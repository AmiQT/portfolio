---
import Layout from "../../layouts/Layout.astro";
import IdeActivityBar from "../../components/software-dev/IdeActivityBar.astro";
import IdeSidebar from "../../components/software-dev/IdeSidebar.astro";
import IdeTabBar from "../../components/software-dev/IdeTabBar.astro";
import MobileNav from "../../components/software-dev/MobileNav.astro";
import { projectsData as projects } from "../../data/software-developer";

// Files for sidebar - Following the 3-file standard
const files = [
    { name: 'projects.json', active: true, icon: '📦', href: 'role-software-developer/projects' },
    { name: 'home-software-developer.ipynb', active: false, icon: '📓', href: 'role-software-developer/' },
];

// Helper for base URL
const getAssetPath = (path: string) => {
    return path.startsWith("http") ? path : import.meta.env.BASE_URL + path;
};

const tabs = [
    { name: 'projects.json', active: true, icon: '📦' },
    { name: 'home-software-developer.ipynb', active: false, icon: '📓', onclick: `window.location.href='${import.meta.env.BASE_URL}role-software-developer/'` }
];
---

<Layout
    title="Development Projects - Noor Azami"
    description="Software development projects including web apps, mobile applications, and full-stack systems showcasing technical expertise."
    canonical="/role-software-developer/projects"
>
    <div class="flex h-screen bg-[#0d1117] text-gray-300 overflow-hidden font-sans transition-colors duration-300">
        <IdeActivityBar />
        <IdeSidebar files={files} />

        <!-- Main Editor Area -->
        <main class="flex-1 flex flex-col min-w-0 bg-[#0d1117] transition-colors duration-300">
            <IdeTabBar tabs={tabs} />

            <!-- Breadcrumbs / Toolbar -->
            <div class="flex items-center gap-2 px-4 py-1 bg-[#0d1117] border-b border-gray-800 text-xs text-gray-500 transition-colors duration-300">
                <span>src</span>
                <span>›</span>
                <span>data</span>
                <span>›</span>
                <span>projects.json</span>
                <div class="ml-auto flex gap-4 text-xs">
                    <span class="text-green-400">{projects.length} projects loaded</span>
                    <span class="text-cyan-400">{projects.filter(p => p.type === 'Full-Stack').length} Full-Stack</span>
                    <span class="text-blue-400">{projects.filter(p => p.type === 'Web').length} Web</span>
                    <span class="text-purple-400">{projects.filter(p => p.type === 'App').length} Mobile</span>
                </div>
            </div>

            <!-- Content Area (Scrollable) -->
            <div class="flex-1 overflow-y-auto p-4 md:p-8 scroll-smooth" id="projects-content">
                <!-- JSON-like Header -->
                <div class="mb-8 p-4 bg-[#161b22] rounded-lg border border-gray-700 font-mono text-sm shadow-xl">
                    <div class="text-gray-400">
                        <span class="text-purple-400">{"{"}</span>
                    </div>
                    <div class="pl-4">
                        <span class="text-blue-400">"title"</span>
                        <span class="text-gray-500">:</span>
                        <span class="text-green-400">"Development Projects"</span>
                        <span class="text-gray-500">,</span>
                    </div>
                    <div class="pl-4">
                        <span class="text-blue-400">"developer"</span>
                        <span class="text-gray-500">:</span>
                        <span class="text-green-400">"Noor Azami"</span>
                        <span class="text-gray-500">,</span>
                    </div>
                    <div class="pl-4">
                        <span class="text-blue-400">"count"</span>
                        <span class="text-gray-500">:</span>
                        <span class="text-orange-400">{projects.length}</span>
                        <span class="text-gray-500">,</span>
                    </div>
                    <div class="pl-4">
                        <span class="text-blue-400">"projects"</span>
                        <span class="text-gray-500">:</span>
                        <span class="text-purple-400">[</span>
                        <span class="text-gray-500 text-xs ml-2">// explore the list below...</span>
                    </div>
                </div>

                <!-- Project Cards Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {projects.map((project, index) => (
                        <div 
                            class="bg-[#161b22] rounded-lg border border-gray-700 overflow-hidden hover:shadow-2xl hover:border-blue-500/50 transition-all group"
                            id={`project-${project.title.toLowerCase().replace(/\s+/g, '-')}`}
                        >
                            <!-- Project Image / Preview -->
                            {project.image === "gradient" ? (
                                <div class="h-40 bg-gradient-to-br from-teal-900/40 to-emerald-900/40 flex items-center justify-center border-b border-gray-700 relative overflow-hidden">
                                    <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"></div>
                                    <div class="text-center z-10">
                                        <div class="w-12 h-12 bg-teal-500/20 rounded-full flex items-center justify-center mx-auto mb-2 backdrop-blur-sm">
                                            <span class="text-2xl">{project.type === 'App' ? '📱' : '🌐'}</span>
                                        </div>
                                        <h4 class="text-xs font-bold text-teal-300">{project.title}</h4>
                                    </div>
                                </div>
                            ) : (
                                <div class="h-40 bg-gray-800 relative overflow-hidden border-b border-gray-700">
                                    <img
                                        src={getAssetPath(project.image)}
                                        alt={project.title}
                                        class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300"
                                        loading="lazy"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-[#161b22] to-transparent opacity-60"></div>
                                </div>
                            )}

                            <!-- Project Details -->
                            <div class="p-4 font-mono text-xs">
                                <div class="flex gap-3 mb-1">
                                    <span class="text-gray-600 w-4 text-right select-none">{index + 1}</span>
                                    <span class="text-purple-400">{"{"}</span>
                                </div>
                                <div class="flex gap-3 mb-1">
                                    <span class="text-gray-600 w-4 text-right select-none">{index + 2}</span>
                                    <div class="pl-4">
                                        <span class="text-blue-400">"name"</span>
                                        <span class="text-gray-500">:</span>
                                        <span class="text-green-400 ml-1">"{project.title}"</span>
                                    </div>
                                </div>
                                <div class="flex gap-3 mb-1">
                                    <span class="text-gray-600 w-4 text-right select-none">{index + 3}</span>
                                    <div class="pl-4">
                                        <span class="text-blue-400">"type"</span>
                                        <span class="text-gray-500">:</span>
                                        <span class={`ml-1 px-1.5 py-0.5 rounded text-[10px] font-sans ${project.type === 'App' ? 'bg-purple-900/40 text-purple-300' : project.type === 'Full-Stack' ? 'bg-cyan-900/40 text-cyan-300' : 'bg-blue-900/40 text-blue-300'}`}>
                                            {project.type}
                                        </span>
                                    </div>
                                </div>
                                <div class="flex gap-3 mb-2">
                                    <span class="text-gray-600 w-4 text-right select-none">{index + 4}</span>
                                    <div class="pl-4 text-gray-400 font-sans line-clamp-2">
                                        {project.desc}
                                    </div>
                                </div>
                                <div class="flex gap-3 mb-3">
                                    <span class="text-gray-600 w-4 text-right select-none">{index + 5}</span>
                                    <span class="text-purple-400">{"}"}</span>
                                </div>
                                <a
                                    href={getAssetPath(project.link)}
                                    class="flex items-center justify-center gap-2 w-full py-2 bg-blue-600 hover:bg-blue-700 text-white rounded text-xs font-sans font-medium transition-colors"
                                >
                                    View Details
                                </a>
                            </div>
                        </div>
                    ))}
                </div>

                <!-- Footer Closing -->
                <div class="mt-8 p-4 bg-[#161b22] rounded-lg border border-gray-700 font-mono text-sm">
                    <div class="pl-4">
                        <span class="text-purple-400">]</span>
                    </div>
                    <div class="text-gray-400">
                        <span class="text-purple-400">{"}"}</span>
                    </div>
                </div>
            </div>
        </main>

        <MobileNav files={files} />
    </div>
</Layout>

<style>
    #projects-content::-webkit-scrollbar {
        width: 12px;
    }
    #projects-content::-webkit-scrollbar-track {
        background: transparent;
    }
    #projects-content::-webkit-scrollbar-thumb {
        background-color: #30363d;
        border-radius: 6px;
        border: 3px solid transparent;
        background-clip: content-box;
    }
</style>

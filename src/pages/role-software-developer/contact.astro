---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/it-support/Header.astro";

const faqs = [
    {
        question: "What technology stack do you use?",
        answer: "I specialize in Full-Stack development using technologies like React, Next.js, Astro, Node.js, and Python. I'm also proficient in mobile development with Flutter.",
    },
    {
        question: "Are you available for freelance projects?",
        answer: "Yes, I am open to freelance opportunities for web development, MVP building, and API integrations.",
    },
    {
        question: "How do we get started?",
        answer: "Simply send me a message through the form below or reach out via LinkedIn. I usually respond within 24 hours.",
    },
];

const contactMethods = [
    {
        name: "Email",
        value: "noorazami@outlook.my",
        icon: "📧",
        href: "mailto:noorazami@outlook.my",
    },
    {
        name: "LinkedIn",
        value: "linkedin.com/in/noor-azami",
        icon: "💼",
        href: "https://www.linkedin.com/in/noor-azami/",
    },
    {
        name: "GitHub",
        value: "github.com/AmiQT",
        icon: "💻",
        href: "https://github.com/AmiQT",
    },
];
---

<Layout
    title="Contact - Software Developer - Noor Azami"
    description="Get in touch with Noor Azami for software development inquiries, collaborations, or project discussions."
    canonical="/role-software-developer/contact"
>
    <Header />

    <main class="pt-16 bg-white dark:bg-[#0d1117] text-gray-900 dark:text-gray-300 transition-colors duration-300">
        <!-- Hero Section -->
        <section
            class="py-24 px-4 sm:px-6 lg:px-8 text-center bg-gradient-to-br from-blue-900 to-slate-900 text-white"
        >
            <div class="container mx-auto max-w-4xl fade-in-scroll">
                <div
                    class="w-20 h-20 mx-auto mb-6 bg-blue-500/20 rounded-full flex items-center justify-center border border-blue-500/30"
                >
                    <span class="text-4xl">🚀</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold mb-4">
                    Let's Build Together
                </h1>
                <p class="text-lg text-gray-300 max-w-2xl mx-auto">
                    Have a project in mind or just want to chat about tech? Drop me a message below.
                </p>
            </div>
        </section>

        <!-- Contact Methods & Form -->
        <section class="py-16 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto max-w-5xl">
                <div class="grid md:grid-cols-2 gap-12">
                    <!-- Contact Info -->
                    <div class="fade-in-scroll">
                        <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">
                            Connect with Me
                        </h2>
                        <p class="text-gray-600 dark:text-gray-400 mb-8">
                            I'm always looking for interesting projects and new connections in the software engineering space.
                        </p>

                        <div class="space-y-4">
                            {
                                contactMethods.map((method) => (
                                    <a
                                        href={method.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-[#161b22] rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-500/50 transition-all group shadow-sm"
                                    >
                                        <div class="w-12 h-12 bg-blue-500/10 rounded-lg flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
                                            <span class="text-2xl">
                                                {method.icon}
                                            </span>
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900 dark:text-white">
                                                {method.name}
                                            </p>
                                            <p class="text-sm text-blue-600 dark:text-blue-400">
                                                {method.value}
                                            </p>
                                        </div>
                                        <span class="ml-auto text-gray-400 group-hover:text-blue-500 transition-colors">
                                            →
                                        </span>
                                    </a>
                                ))
                            }
                        </div>
                    </div>

                    <!-- Contact Form -->
                    <div class="fade-in-scroll">
                        <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">Send a Message</h2>
                        <form id="contact-form" class="space-y-4">
                            <div>
                                <label
                                    for="name"
                                    class="block text-sm font-medium mb-2"
                                    >Name</label
                                >
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-gray-700 rounded-lg focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
                                    placeholder="Your name"
                                />
                            </div>

                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium mb-2"
                                    >Email</label
                                >
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-gray-700 rounded-lg focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
                                    placeholder="your@email.com"
                                />
                            </div>

                            <div>
                                <label
                                    for="subject"
                                    class="block text-sm font-medium mb-2"
                                    >Inquiry Type</label
                                >
                                <select
                                    id="subject"
                                    name="subject"
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-gray-700 rounded-lg focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
                                >
                                    <option value="project">Project Proposal</option>
                                    <option value="freelance">Freelance Inquiry</option>
                                    <option value="collaboration">Open Source Collaboration</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>

                            <div>
                                <label
                                    for="message"
                                    class="block text-sm font-medium mb-2"
                                    >Message</label
                                >
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-gray-700 rounded-lg focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors resize-none"
                                    placeholder="Tell me about your project..."
                                ></textarea>
                            </div>

                            <button
                                type="submit"
                                class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-bold text-lg transition-colors"
                            >
                                Send Message
                            </button>
                        </form>

                        <div
                            id="form-success"
                            class="hidden mt-4 p-4 bg-green-500/20 border border-green-500/30 rounded-lg text-center"
                        >
                            <span class="text-green-600 dark:text-green-400"
                                >✓ Message sent successfully! I'll get back to you soon.</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-[#161b22]/50">
            <div class="container mx-auto max-w-3xl">
                <h2 class="text-2xl font-bold text-center mb-8 text-gray-900 dark:text-white">
                    FAQ
                </h2>
                <div class="space-y-4">
                    {
                        faqs.map((faq, index) => (
                            <div class="bg-white dark:bg-[#0d1117] rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden fade-in-scroll shadow-sm">
                                <button
                                    class="w-full px-6 py-4 flex items-center justify-between text-left faq-toggle group"
                                    data-index={index}
                                >
                                    <span class="font-medium group-hover:text-blue-500 transition-colors">
                                        {faq.question}
                                    </span>
                                    <span class="text-blue-500 faq-icon">
                                        +
                                    </span>
                                </button>
                                <div
                                    class="px-6 pb-4 hidden faq-answer"
                                    data-index={index}
                                >
                                    <p class="text-gray-600 dark:text-gray-400">
                                        {faq.answer}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-24 px-4 sm:px-6 lg:px-8 text-center">
            <div class="container mx-auto max-w-4xl fade-in-scroll">
                <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-white">Explore My Work</h2>
                <div class="flex flex-wrap justify-center gap-4">
                    <a
                        href={import.meta.env.BASE_URL +
                            "role-software-developer/projects"}
                        class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-bold transition-colors"
                    >
                        View Projects
                    </a>
                    <a
                        href={import.meta.env.BASE_URL + "role-software-developer/"}
                        class="px-8 py-3 font-bold border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-700 dark:text-gray-300"
                    >
                        Back to Profile
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .fade-in-scroll {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp 0.6s ease-out forwards;
    }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    localStorage.setItem("selectedProfile", "software-developer");

    // FAQ Toggle
    document.querySelectorAll(".faq-toggle").forEach((button) => {
        button.addEventListener("click", () => {
            const index = button.getAttribute("data-index");
            const answer = document.querySelector(
                `.faq-answer[data-index="${index}"]`,
            );
            const icon = button.querySelector(".faq-icon");

            if (answer) {
                answer.classList.toggle("hidden");
                if (icon) {
                    icon.textContent = answer.classList.contains("hidden")
                        ? "+"
                        : "−";
                }
            }
        });
    });

    // Form Submit
    const form = document.getElementById("contact-form");
    const successMessage = document.getElementById("form-success");

    form?.addEventListener("submit", (e) => {
        e.preventDefault();
        if (successMessage) {
            successMessage.classList.remove("hidden");
            (form as HTMLFormElement).reset();
            setTimeout(() => {
                successMessage.classList.add("hidden");
            }, 5000);
        }
    });
</script>

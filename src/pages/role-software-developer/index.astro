---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProfileSelector from '../../components/ProfileSelector.astro';
---

<Layout title="Software Developer - Noor Azami" description="Full-Stack Developer Portfolio - Web development, mobile apps, and creative software solutions." canonical="/role-software-developer/">
	<Header />
	<ProfileSelector />
	<main class="pt-16">
		<section class="relative flex items-center justify-center h-screen text-center px-4 sm:px-6 lg:px-8 animated-gradient">
			<div class="z-10">
				<div class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-green-500/20 border border-green-500/40 rounded-full">
					<span class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></span>
					<span class="text-green-400 font-semibold text-sm">Software Developer</span>
				</div>
				<h1 class="text-5xl md:text-7xl font-bold mb-4 leading-tight text-white">Noor Azami</h1>
				<p class="text-xl md:text-2xl font-bold mb-6 max-w-4xl mx-auto leading-relaxed">
					Full-Stack Developer crafting elegant software solutions with web technologies, mobile apps, and creative digital experiences
				</p>
				<p class="text-lg text-text-secondary mb-8 max-w-3xl mx-auto font-medium">
					<span class="text-white font-semibold">Creative Developer</span> 
					<span class="text-text-secondary mx-2">|</span> 
					<span class="text-text-secondary">UI/UX Focused</span>
				</p>
				<div class="flex flex-wrap justify-center gap-4 mb-8">
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-green-500/20 to-emerald-600/20 border border-green-500/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-green-500/30 hover:to-emerald-600/30 hover:border-green-500/60 hover:scale-105 hover:shadow-lg hover:shadow-green-500/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						💻 Full-Stack Development
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-green-500/20 to-emerald-600/20 border border-green-500/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-green-500/30 hover:to-emerald-600/30 hover:border-green-500/60 hover:scale-105 hover:shadow-lg hover:shadow-green-500/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						📱 Mobile Apps
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-green-500/20 to-emerald-600/20 border border-green-500/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-green-500/30 hover:to-emerald-600/30 hover:border-green-500/60 hover:scale-105 hover:shadow-lg hover:shadow-green-500/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🎨 UI/UX Design
					</span>
				</div>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/role-software-developer/projects" class="button_primary text-lg font-bold px-8 py-3">
						View Projects
					</a>
					<a href="/portfolio/contact" class="button_secondary text-lg font-bold px-8 py-3">
						Contact Me
					</a>
				</div>
			</div>
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20">
				<a class="animate-bounce" href="#expertise" aria-label="Scroll to expertise section">
					<svg class="h-8 w-8 text-text-secondary hover:text-green-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
					</svg>
					<span class="sr-only">Scroll to expertise section</span>
				</a>
			</div>
		</section>

		<section id="expertise" class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto max-w-6xl">
				<h2 class="text-4xl md:text-5xl font-bold text-center mb-16 fade-in-scroll">Development Expertise</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 fade-in-scroll">
					<!-- Web Development -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-green-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Web Development</h3>
						<p class="text-text-secondary">Modern web applications with HTML, CSS, JavaScript, React, and responsive design principles</p>
					</div>

					<!-- Mobile Development -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-green-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Mobile Apps</h3>
						<p class="text-text-secondary">Cross-platform mobile development with Flutter, creating beautiful and functional user experiences</p>
					</div>

					<!-- Backend Development -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-green-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Backend Development</h3>
						<p class="text-text-secondary">Server-side development, APIs, databases, and cloud-based solutions with Python</p>
					</div>

					<!-- UI/UX Design -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-green-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">UI/UX Design</h3>
						<p class="text-text-secondary">User interface design, prototyping, and creating intuitive digital experiences with design tools</p>
					</div>

					<!-- Database Design -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-green-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Database Design</h3>
						<p class="text-text-secondary">Relational and non-relational databases, data modeling, and query optimization</p>
					</div>

					<!-- Problem Solving -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-green-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Problem Solving</h3>
						<p class="text-text-secondary">Algorithm design, optimization, debugging, and creative solutions to complex technical challenges</p>
					</div>
				</div>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8 bg-accent-color">
			<div class="container mx-auto max-w-6xl text-center fade-in-scroll">
				<h2 class="text-4xl font-bold mb-6">Featured Development Projects</h2>
				<p class="text-lg text-text-secondary mb-12 max-w-3xl mx-auto">Full-stack applications, mobile apps, and web projects demonstrating technical expertise and creative design</p>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<a href="/portfolio/projects/stylehub" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-green-500/20 text-green-400 text-xs font-bold rounded-full">WEB APP</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">StyleHub</h3>
						<p class="text-text-secondary mb-4">Fashion e-commerce platform with modern web technologies and responsive design</p>
						<span class="inline-flex items-center gap-2 text-green-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>

					<a href="/portfolio/projects/nasi-lemak-burger" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-green-500/20 text-green-400 text-xs font-bold rounded-full">MOBILE APP</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">Nasi Lemak Burger</h3>
						<p class="text-text-secondary mb-4">Food delivery mobile application built with Flutter for seamless user experience</p>
						<span class="inline-flex items-center gap-2 text-green-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>

					<a href="/portfolio/projects/rumah-tenang" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-green-500/20 text-green-400 text-xs font-bold rounded-full">SYSTEM</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">Rumah Tenang</h3>
						<p class="text-text-secondary mb-4">Comprehensive hotel management system with full-stack architecture and database design</p>
						<span class="inline-flex items-center gap-2 text-green-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>

					<a href="/portfolio/projects/healthy-food-app" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-green-500/20 text-green-400 text-xs font-bold rounded-full">MOBILE APP</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">Healthy Food App</h3>
						<p class="text-text-secondary mb-4">Nutrition tracking and meal planning application with modern mobile design</p>
						<span class="inline-flex items-center gap-2 text-green-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>
				</div>

				<a href="/portfolio/role-software-developer/projects" class="button_primary text-lg font-bold px-8 py-3 mt-12">
					View All Projects
				</a>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto max-w-6xl text-center fade-in-scroll">
				<h2 class="text-4xl font-bold mb-6">Tech Stack & Skills</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16">
					<div class="text-left">
						<h3 class="text-2xl font-bold mb-6">Frontend & Mobile</h3>
						<div class="space-y-3">
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>HTML5, CSS3, JavaScript</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>React & Modern Frameworks</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Flutter Mobile Development</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Responsive & Adaptive Design</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Tailwind CSS & UI Libraries</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>User Experience Design</span>
							</div>
						</div>
					</div>

					<div class="text-left">
						<h3 class="text-2xl font-bold mb-6">Backend & Tools</h3>
						<div class="space-y-3">
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Python Programming</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Database Design (SQL & NoSQL)</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>API Development & REST</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Git & Version Control</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Adobe Design Suite</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-green-400 rounded-full"></span>
								<span>Cloud & Deployment</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8 bg-accent-color text-center">
			<div class="container mx-auto max-w-4xl fade-in-scroll">
				<h2 class="text-4xl font-bold mb-6">Let's Build Something Amazing</h2>
				<p class="text-lg text-text-secondary mb-8">Interested in collaboration or want to discuss a project? Let's connect!</p>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/contact" class="button_primary text-lg font-bold px-8 py-3">
						Get In Touch
					</a>
					<a href="/portfolio/role-software-developer/projects" class="button_secondary text-lg font-bold px-8 py-3">
						View All Projects
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	localStorage.setItem('selectedProfile', 'software-developer');
</script>

---
import Layout from "../../../layouts/Layout.astro";
import IdeActivityBar from "../../../components/software-dev/IdeActivityBar.astro";
import IdeSidebar from "../../../components/software-dev/IdeSidebar.astro";
import IdeTabBar from "../../../components/software-dev/IdeTabBar.astro";
import MobileNav from "../../../components/software-dev/MobileNav.astro";
import NotebookCell from "../../../components/software-dev/NotebookCell.astro";
import InfraNote from "../../../components/InfraNote.astro";

const project = {
    title: "Enterprise IT Asset Automation",
    type: "Data Engineering / Automation",
    description:
        "Engineered a robust enterprise automation suite using Python and Pandas that eliminated 90% of manual hardware tracking toil for 200+ employees.",
    githubUrl: "https://github.com/AmiQT/it-asset-automation",
};

const technologies = [
    { name: "Python 3.12", color: "blue" },
    { name: "Pandas", color: "green" },
    { name: "OpenPyXL", color: "cyan" },
    { name: "Win32Com", color: "purple" },
];

const files = [
    {
        name: "it_asset_automation.py",
        active: true,
        icon: "🐍",
        href: import.meta.env.BASE_URL + "role-software-developer/projects/it-asset-automation",
    },
    {
        name: "projects.json",
        active: false,
        icon: "📦",
        href: import.meta.env.BASE_URL + "role-software-developer/projects",
    },
    {
        name: "home-software-developer.ipynb",
        active: false,
        icon: "📓",
        href: import.meta.env.BASE_URL + "role-software-developer/",
    },
];

const tabs = [
    { name: 'it_asset_automation.py', active: true, icon: '🐍' },
    { name: 'projects.json', active: false, icon: '📦', onclick: `window.location.href='${import.meta.env.BASE_URL}role-software-developer/projects'` },
    { name: 'home-software-developer.ipynb', active: false, icon: '📓', onclick: `window.location.href='${import.meta.env.BASE_URL}role-software-developer/'` }
];
---

<Layout
    title="IT Asset Automation - Software Development | Noor Azami"
    description={project.description}
>
    <div
        class="flex h-screen bg-[#0d1117] text-gray-300 overflow-hidden font-sans transition-colors duration-300"
    >
        <IdeActivityBar />
        <IdeSidebar files={files} />

        <main
            class="flex-1 flex flex-col min-w-0 bg-[#0d1117] transition-colors duration-300"
        >
            <IdeTabBar tabs={tabs} />

            <!-- Breadcrumbs -->
            <div
                class="flex items-center gap-2 px-4 py-1 bg-[#0d1117] border-b border-gray-800 text-xs text-gray-500"
            >
                <span>src</span><span>›</span><span>scripts</span><span>›</span><span>it_asset_automation.py</span>
            </div>

            <div
                class="flex-1 overflow-y-auto p-4 md:p-8 scroll-smooth"
                id="project-content"
            >
                <InfraNote />
                <NotebookCell
                    cellNumber={1}
                    code={`# Data Transformation Pipeline\n# Handling 200+ employee records across multiple portals\n\nimport pandas as pd\n\ndef process_inventory(file_path):\n    df = pd.read_excel(file_path)\n    # Logic to clean and normalize hardware IDs\n    df_clean = df.drop_duplicates(subset=['hardware_id']).fillna('N/A')\n    return df_clean`}
                >
                    <section
                        class="relative flex flex-col items-center justify-center text-center py-12 md:py-16 bg-gradient-to-br from-teal-900 to-slate-900 rounded-lg overflow-hidden border border-emerald-500/30 shadow-2xl"
                    >
                        <div class="z-10 px-4">
                            <div class="flex justify-center mb-4">
                                <span
                                    class="px-4 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-sm text-emerald-300"
                                    >Data Operations</span
                                >
                            </div>
                            <h1
                                class="text-3xl md:text-4xl font-bold mb-4 text-white"
                            >
                                {project.title}
                            </h1>
                            <p
                                class="text-base md:text-lg font-medium mb-6 max-w-2xl mx-auto text-gray-200"
                            >
                                {project.description}
                            </p>
                            <div
                                class="flex flex-wrap justify-center gap-2 mb-6"
                            >
                                {
                                    technologies.map((tech) => (
                                        <span class="px-3 py-1 bg-black/30 backdrop-blur-md border border-white/20 rounded-full text-xs text-white">
                                            {tech.name}
                                        </span>
                                    ))
                                }
                            </div>
                            <div class="flex justify-center gap-4">
                                <a
                                    href={project.githubUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-medium transition-colors"
                                >
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                    </svg>
                                    Source Code
                                </a>
                            </div>
                        </div>
                    </section>
                </NotebookCell>

                <NotebookCell
                    cellNumber={2}
                    code={`# Automating Multi-Channel Dispatch\n# Implementing Rate Limiting to bypass SMTP bottlenecks\n\nimport time\n\ndef dispatch_alerts(targets):\n    for batch in chunk(targets, 10):\n        send_batch(batch)\n        time.sleep(5)  # Throttle to avoid throttling`}
                >
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-[#161b22] p-6 rounded-lg border border-gray-700">
                            <h3 class="font-bold text-white mb-3">Logic Optimization</h3>
                            <p class="text-sm text-gray-400">
                                Refactored original loops into asynchronous batch processors, achieving a baseline stability for large scale notification dispatch without triggering enterprise WAF filters.
                            </p>
                        </div>
                        <div class="bg-[#161b22] p-6 rounded-lg border border-gray-700">
                            <h3 class="font-bold text-white mb-3">Data Resilience</h3>
                            <p class="text-sm text-gray-400">
                                Integrated automatic CSV state saving. The system tracks its own progress, allowing for zero-duplicate reruns even in case of connection failure.
                            </p>
                        </div>
                    </div>
                </NotebookCell>

                <div class="mt-8 text-center pb-8">
                    <a
                        href={import.meta.env.BASE_URL + "role-software-developer/projects"}
                        class="inline-flex items-center gap-2 px-6 py-3 bg-[#161b22] border border-gray-700 rounded-lg text-sm font-medium text-gray-300 hover:border-emerald-500/50 hover:text-emerald-400 transition-all font-mono"
                    >
                        <span>←</span> Back to projects.json
                    </a>
                </div>
            </div>
        </main>
        <MobileNav files={files} />
    </div>
</Layout>

<style>
    #project-content::-webkit-scrollbar {
        width: 12px;
    }
    #project-content::-webkit-scrollbar-track {
        background: transparent;
    }
    #project-content::-webkit-scrollbar-thumb {
        background-color: #30363d;
        border-radius: 6px;
        border: 3px solid transparent;
        background-clip: content-box;
    }
</style>

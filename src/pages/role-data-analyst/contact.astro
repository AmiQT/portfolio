---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/it-support/Header.astro";

const faqs = [
    {
        question: "What analytics tools do you use?",
        answer: "I specialize in Power BI for dashboarding and visualization. I also use Excel for deep data cleaning and Python for advanced statistical analysis.",
    },
    {
        question: "Can you help with business intelligence automation?",
        answer: "Definitely! I can help automate data collection and create live dashboards that provide real-time business insights.",
    },
    {
        question: "How do you handle data privacy?",
        answer: "Data security is a priority. I follow best practices for data handling and am happy to sign NDAs for sensitive business projects.",
    },
];

const contactMethods = [
    {
        name: "Email",
        value: "noorazami@outlook.my",
        icon: "📧",
        href: "mailto:noorazami@outlook.my",
    },
    {
        name: "LinkedIn",
        value: "linkedin.com/in/noor-azami",
        icon: "💼",
        href: "https://www.linkedin.com/in/noor-azami/",
    },
    {
        name: "Power BI Portfolio",
        value: "View Dashboards",
        icon: "📊",
        href: "/role-data-analyst/projects",
    },
];
---

<Layout
    title="Contact - Data Analyst - Noor Azami"
    description="Get in touch with Noor Azami for data analysis inquiries, Power BI collaborations, or BI project discussions."
    canonical="/role-data-analyst/contact"
>
    <Header />

    <main class="pt-16 bg-white dark:bg-[#020617] text-gray-900 dark:text-gray-300">
        <!-- Hero Section -->
        <section
            class="py-24 px-4 sm:px-6 lg:px-8 text-center bg-gradient-to-br from-amber-900 to-slate-900 text-white"
        >
            <div class="container mx-auto max-w-4xl fade-in-scroll">
                <div
                    class="w-20 h-20 mx-auto mb-6 bg-amber-500/20 rounded-full flex items-center justify-center border border-amber-500/30"
                >
                    <span class="text-4xl">📊</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold mb-4">
                    Turning Data into Insights
                </h1>
                <p class="text-lg text-amber-100/80 max-w-2xl mx-auto">
                    Have a data challenge? Let's analyze it together and find the story behind the numbers.
                </p>
            </div>
        </section>

        <!-- Contact Methods & Form -->
        <section class="py-16 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto max-w-5xl">
                <div class="grid md:grid-cols-2 gap-12">
                    <!-- Contact Info -->
                    <div class="fade-in-scroll">
                        <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">
                            Data Inquiry
                        </h2>
                        <p class="text-gray-600 dark:text-gray-400 mb-8">
                            Whether you need a full BI overhaul or just a clean dashboard, I'm here to help.
                        </p>

                        <div class="space-y-4">
                            {
                                contactMethods.map((method) => (
                                    <a
                                        href={method.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-slate-900/50 rounded-lg border border-amber-500/20 hover:border-amber-500/40 transition-all group"
                                    >
                                        <div class="w-12 h-12 bg-amber-500/10 rounded-lg flex items-center justify-center group-hover:bg-amber-500/20 transition-colors">
                                            <span class="text-2xl">
                                                {method.icon}
                                            </span>
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900 dark:text-white">
                                                {method.name}
                                            </p>
                                            <p class="text-sm text-amber-600 dark:text-amber-400">
                                                {method.value}
                                            </p>
                                        </div>
                                        <span class="ml-auto text-gray-400 group-hover:text-amber-500 transition-colors">
                                            →
                                        </span>
                                    </a>
                                ))
                            }
                        </div>
                    </div>

                    <!-- Contact Form -->
                    <div class="fade-in-scroll">
                        <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">Request Analysis</h2>
                        <form id="contact-form" class="space-y-4">
                            <div>
                                <label
                                    for="name"
                                    class="block text-sm font-medium mb-2"
                                    >Name</label
                                >
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-amber-500/20 rounded-lg focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500 transition-colors"
                                    placeholder="Your name"
                                />
                            </div>

                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium mb-2"
                                    >Email</label
                                >
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-amber-500/20 rounded-lg focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500 transition-colors"
                                    placeholder="your@email.com"
                                />
                            </div>

                            <div>
                                <label
                                    for="subject"
                                    class="block text-sm font-medium mb-2"
                                    >Service Needed</label
                                >
                                <select
                                    id="subject"
                                    name="subject"
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-amber-500/20 rounded-lg focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500 transition-colors"
                                >
                                    <option value="dashboard">Power BI Dashboarding</option>
                                    <option value="cleaning">Data Cleaning/Prep</option>
                                    <option value="automation">Reports Automation</option>
                                    <option value="other">Other Inquiry</option>
                                </select>
                            </div>

                            <div>
                                <label
                                    for="message"
                                    class="block text-sm font-medium mb-2"
                                    >Project Details</label
                                >
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-amber-500/20 rounded-lg focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500 transition-colors resize-none"
                                    placeholder="Describe your data challenge..."
                                ></textarea>
                            </div>

                            <button
                                type="submit"
                                class="w-full bg-amber-600 hover:bg-amber-700 text-white py-3 rounded-lg font-bold text-lg transition-colors"
                            >
                                Send Request
                            </button>
                        </form>

                        <div
                            id="form-success"
                            class="hidden mt-4 p-4 bg-green-500/20 border border-green-500/30 rounded-lg text-center"
                        >
                            <span class="text-green-600 dark:text-green-400"
                                >✓ Request sent! I'll get back to you soon.</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-slate-900/50">
            <div class="container mx-auto max-w-3xl">
                <h2 class="text-2xl font-bold text-center mb-8 text-gray-900 dark:text-white">
                    Data Analytics FAQ
                </h2>
                <div class="space-y-4">
                    {
                        faqs.map((faq, index) => (
                            <div class="bg-white dark:bg-slate-900 rounded-lg border border-amber-500/20 overflow-hidden fade-in-scroll shadow-sm">
                                <button
                                    class="w-full px-6 py-4 flex items-center justify-between text-left faq-toggle group"
                                    data-index={index}
                                >
                                    <span class="font-medium group-hover:text-amber-500 transition-colors">
                                        {faq.question}
                                    </span>
                                    <span class="text-amber-500 faq-icon">
                                        +
                                    </span>
                                </button>
                                <div
                                    class="px-6 pb-4 hidden faq-answer"
                                    data-index={index}
                                >
                                    <p class="text-slate-600 dark:text-slate-400">
                                        {faq.answer}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-24 px-4 sm:px-6 lg:px-8 text-center">
            <div class="container mx-auto max-w-4xl fade-in-scroll">
                <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-white">Check My Insights</h2>
                <div class="flex flex-wrap justify-center gap-4">
                    <a
                        href={import.meta.env.BASE_URL +
                            "role-data-analyst/projects"}
                        class="bg-amber-600 hover:bg-amber-700 text-white px-8 py-3 rounded-lg font-bold transition-colors"
                    >
                        View Case Studies
                    </a>
                    <a
                        href={import.meta.env.BASE_URL + "role-data-analyst/"}
                        class="px-8 py-3 font-bold border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-700 dark:text-gray-300"
                    >
                        Back to Profile
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .fade-in-scroll {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp 0.6s ease-out forwards;
    }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    localStorage.setItem("selectedProfile", "data-analyst");

    // FAQ Toggle
    document.querySelectorAll(".faq-toggle").forEach((button) => {
        button.addEventListener("click", () => {
            const index = button.getAttribute("data-index");
            const answer = document.querySelector(
                `.faq-answer[data-index="${index}"]`,
            );
            const icon = button.querySelector(".faq-icon");

            if (answer) {
                answer.classList.toggle("hidden");
                if (icon) {
                    icon.textContent = answer.classList.contains("hidden")
                        ? "+"
                        : "−";
                }
            }
        });
    });

    // Form Submit
    const form = document.getElementById("contact-form");
    const successMessage = document.getElementById("form-success");

    form?.addEventListener("submit", (e) => {
        e.preventDefault();
        if (successMessage) {
            successMessage.classList.remove("hidden");
            (form as HTMLFormElement).reset();
            setTimeout(() => {
                successMessage.classList.add("hidden");
            }, 5000);
        }
    });
</script>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Home - Software Developer - Noor Azami" description="Software Developer Portfolio - Full-stack development, web applications, and software engineering." canonical="/home-software-developer/">
	<Header />
	<main class="pt-16">
		<section class="relative flex items-center justify-center h-screen text-center px-4 sm:px-6 lg:px-8 animated-gradient">
			<div class="z-10">
				<h1 class="text-5xl md:text-7xl font-bold mb-4 leading-tight text-white">Noor Azami</h1>
				<p class="text-xl md:text-2xl font-bold mb-6 max-w-4xl mx-auto leading-relaxed">
					A passionate full-stack developer crafting elegant solutions through code, seeking to build innovative software with a forward-thinking development team.
				</p>
				<p class="text-lg text-text-secondary mb-8 max-w-3xl mx-auto font-medium">
					<span class="text-white font-semibold">Seeking Software Developer Opportunities</span> 
					<span class="text-text-secondary mx-2">|</span> 
					<span class="text-text-secondary">Open to Remote/Hybrid/Relocation</span>
				</p>
				<div class="flex flex-wrap justify-center gap-4 mb-8">
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-[var(--primary-color)]/20 to-[var(--button-hover)]/20 border border-[var(--primary-color)]/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-[var(--primary-color)]/30 hover:to-[var(--button-hover)]/30 hover:border-[var(--primary-color)]/60 hover:scale-105 hover:shadow-lg hover:shadow-[var(--primary-color)]/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						📍 Remote Ready
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-[var(--primary-color)]/20 to-[var(--button-hover)]/20 border border-[var(--primary-color)]/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-[var(--primary-color)]/30 hover:to-[var(--button-hover)]/30 hover:border-[var(--primary-color)]/60 hover:scale-105 hover:shadow-lg hover:shadow-[var(--primary-color)]/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🏢 Hybrid Preferred
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-[var(--primary-color)]/20 to-[var(--button-hover)]/20 border border-[var(--primary-color)]/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-[var(--primary-color)]/30 hover:to-[var(--button-hover)]/30 hover:border-[var(--primary-color)]/60 hover:scale-105 hover:shadow-lg hover:shadow-[var(--primary-color)]/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🌍 Relocation Open
					</span>
				</div>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/contact" class="button_primary text-lg font-bold px-8 py-3">
						Get In Touch
					</a>
					<a href={import.meta.env.BASE_URL + "assets/Software Developer Azami.pdf"} download class="button_secondary text-lg font-bold px-8 py-3">
						Download Resume
					</a>
				</div>
			</div>
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20">
				<a class="animate-bounce" href="#about" aria-label="Scroll to about section">
					<svg class="h-8 w-8 text-text-secondary hover:text-primary-color transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
					</svg>
					<span class="sr-only">Scroll to about section</span>
				</a>
			</div>
		</section>

		<!-- Profile Guide Section -->
		<section class="py-12 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-blue-500/10 to-green-500/10 border-y border-gray-700/50">
			<div class="container mx-auto max-w-4xl">
				<div class="flex flex-col md:flex-row items-center justify-between gap-8">
					<div class="flex-1">
						<h3 class="text-xl font-semibold mb-3 flex items-center gap-2">
							<svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
							</svg>
							Switch Profiles
						</h3>
						<p class="text-text-secondary mb-4">
							Want to see your IT Support profile? Look for the <span class="font-semibold text-white">profile icon button</span> in the bottom-left corner to switch between Developer and IT Support portfolios instantly.
						</p>
						<div class="flex flex-wrap gap-4">
							<div class="flex items-center gap-2">
								<span class="px-3 py-1 bg-green-500/20 text-green-400 border border-green-500/30 rounded-full text-sm font-medium">💻 Currently: Developer</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="px-3 py-1 bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded-full text-sm font-medium">🖥️ Available: IT Support</span>
							</div>
						</div>
					</div>
					<div class="flex-shrink-0">
						<div class="w-20 h-20 bg-gradient-to-br from-gray-700 to-gray-800 rounded-full border-2 border-dashed border-gray-600 flex items-center justify-center relative group">
							<svg class="w-10 h-10 text-gray-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"></path>
							</svg>
							<div class="absolute -top-2 -right-2 w-6 h-6 bg-green-500 rounded-full border-2 border-gray-900 flex items-center justify-center">
								<svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
									<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L9 4.414V16a1 1 0 102 0V4.414l6.293 6.293a1 1 0 001.414-1.414l-7-7z"></path>
								</svg>
							</div>
						</div>
						<p class="text-xs text-gray-500 text-center mt-2">Profile Button</p>
					</div>
				</div>
			</div>
		</section>

		<section id="about" class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center fade-in-scroll">
					<div class="w-full aspect-square max-w-md mx-auto lg:mx-0 rounded-lg bg-center bg-no-repeat bg-cover" style={`background-image: url("${import.meta.env.BASE_URL}assets/profile.webp")`}></div>
					<div class="text-left">
						<h2 class="text-3xl font-bold mb-4">About Me</h2>
						<p class="text-lg text-text-secondary leading-relaxed mb-6">
							I am a passionate software developer currently pursuing an IT degree at Universiti Tun Hussein Onn Malaysia. With expertise in full-stack development, I build responsive web applications and solve complex problems through clean, efficient code.
						</p>
						<a href={import.meta.env.BASE_URL + "about"} class="button_primary">More About Me</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Development Focus Section -->
		<section id="what-i-do" class="py-24 px-4 sm:px-6 lg:px-8 bg-[var(--accent-color)]/20">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 fade-in-scroll">Development Expertise</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<div class="card text-center fade-in-scroll">
						<div class="mb-4">
							<svg class="w-12 h-12 mx-auto text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
						</div>
						<h3 class="text-xl font-semibold mb-2">Full-Stack Development</h3>
						<p class="text-text-secondary">React, Vue.js, Node.js, and database design for complete web solutions.</p>
					</div>
					<div class="card text-center fade-in-scroll">
						<div class="mb-4">
							<svg class="w-12 h-12 mx-auto text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
						</div>
						<h3 class="text-xl font-semibold mb-2">UI/UX Implementation</h3>
						<p class="text-text-secondary">Responsive design, accessibility, and pixel-perfect implementations.</p>
					</div>
					<div class="card text-center fade-in-scroll">
						<div class="mb-4">
							<svg class="w-12 h-12 mx-auto text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
						</div>
						<h3 class="text-xl font-semibold mb-2">Performance & Optimization</h3>
						<p class="text-text-secondary">Fast loading times, efficient algorithms, and scalable architecture.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Development Projects Section -->
		<section id="projects" class="py-24 px-4 sm:px-6 lg:px-8 bg-[var(--accent-color)]/20">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 fade-in-scroll">Featured Development Projects</h2>
				<div class="projects-grid">
				<!-- Project: StyleHub -->
				<div class="project-card fade-in-scroll" data-category="web-dev">
					<div class="project-image-container">
						<div class="w-full h-full bg-gradient-to-br from-pink-500/20 to-purple-500/20 rounded-lg flex items-center justify-center border border-pink-500/30">
							<div class="text-center">
								<div class="w-16 h-16 bg-pink-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
									<svg class="w-8 h-8 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
									</svg>
								</div>
								<h4 class="text-sm font-bold text-pink-400">StyleHub</h4>
							</div>
						</div>
					</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">StyleHub - Fashion E-Commerce Platform</h3>
								<div class="project-badges">
									<span class="project-badge web-dev">Web Development</span>
								</div>
							</div>
							<p class="project-description mb-4">Full-stack fashion e-commerce platform with product catalog, shopping cart, and payment integration.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/stylehub"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

				<!-- Project: Rumah Tenang -->
				<div class="project-card fade-in-scroll" data-category="web-dev">
					<div class="project-image-container">
						<img src={import.meta.env.BASE_URL + "assets/rumah_tenang.webp"} alt="Rumah Tenang Project" class="w-full h-full object-contain rounded-lg" width="368" height="178" loading="lazy">
					</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Rumah Tenang - Mental Health Platform</h3>
								<div class="project-badges">
									<span class="project-badge web-dev">Web Development</span>
								</div>
							</div>
							<p class="project-description mb-4">Mental wellness community platform with resources, support groups, and professional counselor connections.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/rumah-tenang"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

				<!-- Project: Nasi Lemak Burger -->
				<div class="project-card fade-in-scroll" data-category="app-dev">
					<div class="project-image-container">
						<img src={import.meta.env.BASE_URL + "assets/burger.webp"} alt="Nasi Lemak Burger Project" class="w-full h-full object-contain rounded-lg" width="354" height="179" loading="lazy">
					</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Nasi Lemak Burger - Restaurant Site</h3>
								<div class="project-badges">
									<span class="project-badge app-dev">Application Development</span>
								</div>
							</div>
							<p class="project-description mb-4">Restaurant website with online ordering system, menu management, and delivery tracking integration.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/nasi-lemak-burger"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

				<!-- Project: Healthy Food App -->
				<div class="project-card fade-in-scroll" data-category="app-dev">
					<div class="project-image-container">
						<div class="mobile-mockup">
							<div class="text-center text-xs font-bold text-white mb-2">Healthy Food App</div>
							<div class="flex-grow bg-gray-700 rounded-lg p-2 text-xs text-gray-300 overflow-hidden">
								<p class="font-semibold mb-1">✨ Features</p>
								<ul class="list-disc list-inside text-gray-400">
									<li>Meal Discovery</li>
									<li>Nutritional Tracking</li>
									<li>Shopping Cart</li>
									<li>Offline Access</li>
								</ul>
							</div>
							<div class="flex justify-center items-center mt-2">
								<svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
							</div>
						</div>
					</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Healthy Food App - Nutrition Tracker</h3>
								<div class="project-badges">
									<span class="project-badge app-dev">Application Development</span>
								</div>
							</div>
							<p class="project-description mb-4">Nutrition tracking application with meal planning, calorie counting, and health analytics dashboard.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/healthy-food-app"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>
				</div>
				<div class="text-center mt-12 fade-in-scroll">
					<a href={import.meta.env.BASE_URL + "role-software-developer/projects"} class="button_secondary">View All Projects</a>
				</div>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto text-center fade-in-scroll">
				<h2 class="text-3xl font-bold mb-6">Ready to Build Something Great?</h2>
				<p class="text-lg text-text-secondary mb-8 max-w-3xl mx-auto">Let's collaborate on innovative projects and create amazing software</p>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/contact" class="button_primary">Get In Touch</a>
					<a href="/portfolio/about" class="button_secondary">Learn More</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	localStorage.setItem('selectedProfile', 'software-developer');
</script>

---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/shared/Icon.astro";
import { profile, allProjects, certifications, techStack } from "../data/devops-engineer.ts";

const baseUrl = import.meta.env.BASE_URL;

const categoryMeta = {
    devops: { label: "DevOps", color: "text-blue-400", bg: "bg-blue-500/15", border: "border-blue-500/30" },
    dev:    { label: "Dev",    color: "text-violet-400", bg: "bg-violet-500/15", border: "border-violet-500/30" },
    it:     { label: "IT Support", color: "text-amber-400", bg: "bg-amber-500/15", border: "border-amber-500/30" },
};

const statusMeta = {
    active:   { label: "Active",   dot: "bg-green-400",  text: "text-green-400" },
    intern:   { label: "Intern",   dot: "bg-amber-400",  text: "text-amber-400" },
    archived: { label: "Archived", dot: "bg-gray-500",   text: "text-gray-400" },
};

const devopsCount = allProjects.filter(p => p.category === "devops").length;
const devCount    = allProjects.filter(p => p.category === "dev").length;
const itCount     = allProjects.filter(p => p.category === "it").length;

const techStackLabels: Record<string, string> = {
    languages:     "Programming Languages",
    frontend:      "Frontend",
    infrastructure: "Infrastructure",
    cicd:          "CI/CD",
    observability: "Observability & Monitoring",
    backend:       "Backend",
    messaging:     "Messaging / Streaming",
    ai:            "AI / ML",
};
---

<Layout
    title={`${profile.name} | ${profile.role}`}
    description={profile.tagline}
    canonical="/"
>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Hero / Profile Card -->
        <section class="mb-10 fade-up">
            <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8">
                <div class="flex flex-col sm:flex-row sm:items-start gap-6">
                    <!-- Avatar -->
                    <div class="shrink-0">
                        <div class="w-20 h-20 rounded-full border-2 border-[#30363d] overflow-hidden">
                            <img src={baseUrl + profile.avatar} alt={profile.name} class="w-full h-full object-cover" />
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex flex-wrap items-center gap-2 mb-1">
                            <h1 class="text-2xl font-bold text-white">{profile.name}</h1>
                            <span class="text-[#8b949e] font-mono text-sm">@AmiQT</span>
                        </div>
                        <p class="text-[#8b949e] text-sm mb-3" id="typewriter-role"></p>
                        <p class="text-[#e6edf3] text-sm leading-relaxed mb-4 max-w-2xl">{profile.bio}</p>

                        <!-- Tags -->
                        <div class="flex flex-wrap gap-2 mb-5">
                            <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2.5 py-1 rounded-full font-mono">
                                IT Support Intern @ DayOne
                            </span>
                            <span class="text-xs text-[#8b949e] bg-[#21262d] border border-[#30363d] px-2.5 py-1 rounded-full font-mono">
                                Final Year · UTHM 2026
                            </span>
                            <span class="text-xs text-blue-400 bg-blue-500/10 border border-blue-500/25 px-2.5 py-1 rounded-full font-mono">
                                Remote / Hybrid / On-site
                            </span>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-wrap gap-3">
                            <a
                                href={baseUrl + "contact"}
                                class="inline-flex items-center gap-2 px-4 py-2 bg-white text-[#0d1117] text-sm font-semibold rounded-lg hover:bg-[#e6edf3] transition-colors"
                            >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 8h18a2 2 0 002-2V6a2 2 0 00-2-2H3a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                                </svg>
                                Contact Me
                            </a>
                            <a
                                href={profile.github}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] hover:bg-[#30363d] transition-colors"
                            >
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                                </svg>
                                GitHub
                            </a>
                            <a
                                href={baseUrl + profile.resume}
                                download
                                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] hover:bg-[#30363d] transition-colors"
                            >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                Resume
                            </a>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="sm:shrink-0 flex sm:flex-col gap-3 flex-wrap">
                        <div class="bg-[#0d1117] border border-[#30363d] rounded-lg px-4 py-3 text-center min-w-[90px]">
                            <div class="text-2xl font-bold text-white" data-counter={allProjects.length}>0</div>
                            <div class="text-xs text-[#8b949e] font-mono">Projects</div>
                        </div>
                        <div class="bg-[#0d1117] border border-[#30363d] rounded-lg px-4 py-3 text-center min-w-[90px]">
                            <div class="text-2xl font-bold text-white" data-counter={certifications.length}>0</div>
                            <div class="text-xs text-[#8b949e] font-mono">Certs</div>
                        </div>
                        <div class="bg-[#0d1117] border border-[#30363d] rounded-lg px-4 py-3 text-center min-w-[90px]">
                            <div class="text-2xl font-bold text-green-400">Open</div>
                            <div class="text-xs text-[#8b949e] font-mono">To Hire</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section class="mb-12 fade-up delay-2">
            <div class="flex items-center justify-between mb-5">
                <h2 class="text-lg font-semibold text-white">Projects</h2>
                <a href={baseUrl + "projects"} class="text-sm text-[#8b949e] hover:text-white transition-colors font-mono">
                    View all →
                </a>
            </div>

            <!-- Filter Tabs -->
            <div class="flex flex-wrap gap-2 mb-6" id="filter-tabs">
                <button data-filter="all" class="filter-tab active-tab px-3 py-1.5 text-sm font-medium rounded-md bg-[#21262d] text-white border border-[#8b949e]/30 transition-colors">
                    All <span class="ml-1 text-xs text-[#8b949e]">{allProjects.length}</span>
                </button>
                <button data-filter="devops" class="filter-tab px-3 py-1.5 text-sm font-medium rounded-md text-[#8b949e] border border-[#30363d] hover:border-blue-500/40 hover:text-blue-400 transition-colors">
                    DevOps <span class="ml-1 text-xs">{devopsCount}</span>
                </button>
                <button data-filter="dev" class="filter-tab px-3 py-1.5 text-sm font-medium rounded-md text-[#8b949e] border border-[#30363d] hover:border-violet-500/40 hover:text-violet-400 transition-colors">
                    Dev <span class="ml-1 text-xs">{devCount}</span>
                </button>
                <button data-filter="it" class="filter-tab px-3 py-1.5 text-sm font-medium rounded-md text-[#8b949e] border border-[#30363d] hover:border-amber-500/40 hover:text-amber-400 transition-colors">
                    IT Support <span class="ml-1 text-xs">{itCount}</span>
                </button>
            </div>

            <!-- Project Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="project-grid">
                {allProjects.map(project => {
                    const cat = categoryMeta[project.category];
                    const stat = statusMeta[project.status];
                    return (
                        <div
                            class="project-card group bg-[#161b22] border border-[#30363d] rounded-xl p-5 hover:border-[#8b949e]/60 transition-all duration-200 flex flex-col"
                            data-category={project.category}
                        >
                            <!-- Card Header -->
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <span class="text-[#8b949e]"><Icon name={project.icon} class="w-5 h-5" /></span>
                                    <div>
                                        <h3 class="font-semibold text-white text-sm group-hover:text-blue-300 transition-colors">{project.title}</h3>
                                        <p class="text-xs text-[#8b949e] font-mono">{project.type}</p>
                                    </div>
                                </div>
                                <span class={`flex items-center gap-1 text-xs font-mono ${stat.text}`}>
                                    <span class={`w-1.5 h-1.5 rounded-full ${stat.dot}`}></span>
                                    {stat.label}
                                </span>
                            </div>

                            <!-- Description -->
                            <p class="text-[#8b949e] text-xs leading-relaxed mb-4 flex-1">{project.description}</p>

                            <!-- Tech tags -->
                            <div class="flex flex-wrap gap-1.5 mb-4">
                                {project.tech.slice(0, 4).map(t => (
                                    <span class="text-[10px] font-mono px-2 py-0.5 bg-[#21262d] text-[#8b949e] rounded border border-[#30363d]">
                                        {t}
                                    </span>
                                ))}
                                {project.tech.length > 4 && (
                                    <span class="text-[10px] font-mono px-2 py-0.5 text-[#8b949e]">+{project.tech.length - 4}</span>
                                )}
                            </div>

                            <!-- Footer -->
                            <div class="flex items-center justify-between">
                                <span class={`text-[10px] font-mono px-2 py-0.5 rounded border ${cat.color} ${cat.bg} ${cat.border}`}>
                                    {cat.label}
                                </span>
                                <div class="flex items-center gap-2">
                                    {project.github && (
                                        <a href={project.github} target="_blank" rel="noopener" class="text-[#8b949e] hover:text-white transition-colors" title="GitHub">
                                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                                            </svg>
                                        </a>
                                    )}
                                    {project.liveUrl && (
                                        <a href={project.liveUrl} target="_blank" rel="noopener" class="text-[#8b949e] hover:text-white transition-colors" title="Live">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                            </svg>
                                        </a>
                                    )}
                                    {project.link.includes("/") && (
                                        <a href={baseUrl + project.link} class="text-xs font-mono text-[#8b949e] hover:text-white transition-colors">
                                            Details →
                                        </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    );
                })}
            </div>
        </section>

        <!-- Skills + Certs Grid -->
        <div class="flex flex-col gap-6 mb-12 fade-up delay-3">

            <!-- Tech Stack -->
            <section class="bg-[#161b22] border border-[#30363d] rounded-xl p-6">
                <h2 class="text-base font-semibold text-white mb-5 flex items-center gap-2">
                    <span class="text-blue-400"><Icon name="settings" class="w-4 h-4" /></span> Tech Stack
                </h2>
                <div class="space-y-4">
                    {Object.entries(techStack).map(([category, items]) => (
                        <div>
                            <p class="text-xs text-[#8b949e] font-mono uppercase tracking-wider mb-2">
                                {techStackLabels[category] ?? category}
                            </p>
                            <div class="flex flex-wrap gap-1.5">
                                {items.map(tech => (
                                    <span class="inline-flex items-center gap-1.5 text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d] hover:border-blue-500/40 hover:text-blue-300 transition-colors">
                                        {tech.devicon ? (
                                            <i class={`${tech.devicon} text-sm`}></i>
                                        ) : (
                                            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"></path>
                                            </svg>
                                        )}
                                        {tech.name}
                                    </span>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Certifications -->
            <section class="bg-[#161b22] border border-[#30363d] rounded-xl p-6">
                <h2 class="text-base font-semibold text-white mb-5 flex items-center gap-2">
                    <span class="text-green-400"><Icon name="check-circle" class="w-4 h-4" /></span> Certifications
                </h2>
                <div class="space-y-3">
                    {certifications.map(cert => (
                        <a
                            href={cert.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-3 p-3 bg-[#0d1117] border border-[#30363d] rounded-lg hover:border-[#8b949e]/60 hover:bg-[#161b22] transition-colors group"
                        >
                            <span class="text-[#8b949e] shrink-0 group-hover:text-white transition-colors"><Icon name={cert.icon} class="w-5 h-5" /></span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-[#e6edf3] font-medium truncate group-hover:text-white transition-colors">{cert.title}</p>
                                <p class="text-xs text-[#8b949e] font-mono">{cert.issuer}</p>
                            </div>
                            <span class="text-xs text-[#8b949e] font-mono shrink-0 border border-[#30363d] px-1.5 py-0.5 rounded">
                                {cert.year}
                            </span>
                        </a>
                    ))}
                </div>

            </section>
        </div>

        <!-- CTA -->
        <section class="fade-up delay-4">
            <div class="bg-gradient-to-r from-blue-500/10 via-[#161b22] to-violet-500/10 border border-[#30363d] rounded-xl p-8 text-center">
                <h2 class="text-xl font-bold text-white mb-2">Let's build something together</h2>
                <p class="text-[#8b949e] text-sm mb-6 max-w-md mx-auto">
                    Available for internships, part-time roles, and collaboration. Based in Malaysia, open to remote work.
                </p>
                <div class="flex flex-wrap justify-center gap-3">
                    <a
                        href={baseUrl + "contact"}
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-[#0d1117] text-sm font-semibold rounded-lg hover:bg-[#e6edf3] transition-colors"
                    >
                        Get in Touch
                    </a>
                    <a
                        href={baseUrl + "experience"}
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                    >
                        View Experience
                    </a>
                </div>
            </div>
        </section>

    </main>
</Layout>

<script>
    const tabs = document.querySelectorAll<HTMLButtonElement>(".filter-tab");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");

    tabs.forEach(tab => {
        tab.addEventListener("click", () => {
            const filter = tab.dataset.filter ?? "all";

            tabs.forEach(t => {
                t.classList.remove("active-tab", "bg-[#21262d]", "text-white", "border-[#8b949e]/30");
                t.classList.add("text-[#8b949e]", "border-[#30363d]");
            });
            tab.classList.add("active-tab", "bg-[#21262d]", "text-white", "border-[#8b949e]/30");
            tab.classList.remove("text-[#8b949e]", "border-[#30363d]");

            cards.forEach(card => {
                const match = filter === "all" || card.dataset.category === filter;
                card.style.display = match ? "" : "none";
            });
        });
    });
</script>

<script define:vars={{ role: profile.role }}>
    // Typing effect for role text
    const el = document.getElementById('typewriter-role');
    if (el) {
        const cursor = document.createElement('span');
        cursor.className = 'typewriter-cursor';
        let i = 0;
        const type = () => {
            if (i < role.length) {
                el.textContent = role.slice(0, ++i);
                el.appendChild(cursor);
                setTimeout(type, 38);
            } else {
                // Remove cursor after 2s
                setTimeout(() => cursor.remove(), 2000);
            }
        };
        // Small delay before typing starts
        setTimeout(type, 400);
    }
</script>

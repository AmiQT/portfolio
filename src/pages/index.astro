---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Home - Noor Azami" description="The portfolio of Noor Azami, showcasing IT support expertise and software development projects." canonical="/">
	<Header />
	<main class="pt-16">
		<!-- Hero Section -->
		<section class="hero-section relative flex items-center justify-center h-screen text-center px-4 sm:px-6 lg:px-8 animated-gradient">
			<div class="z-10">
				<h1 class="text-5xl md:text-7xl font-bold mb-4 leading-tight text-white">Noor Azami</h1>
				<p class="text-xl md:text-2xl font-bold mb-6 max-w-4xl mx-auto leading-relaxed">
					Full-Stack Developer crafting elegant software solutions with web technologies, mobile apps, and creative digital experiences.
				</p>
				<p class="text-lg text-text-secondary mb-8 max-w-3xl mx-auto font-medium">
					<span class="text-white font-semibold">Creative Developer</span> 
					<span class="text-text-secondary mx-2">|</span> 
					<span class="text-text-secondary">UI/UX Focused</span>
				</p>
				<div class="flex flex-wrap justify-center gap-4 mb-8">
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-[var(--primary-color)]/20 to-[var(--button-hover)]/20 border border-[var(--primary-color)]/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-[var(--primary-color)]/30 hover:to-[var(--button-hover)]/30 hover:border-[var(--primary-color)]/60 hover:scale-105 hover:shadow-lg hover:shadow-[var(--primary-color)]/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						💻 Full-Stack Development
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-[var(--primary-color)]/20 to-[var(--button-hover)]/20 border border-[var(--primary-color)]/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-[var(--primary-color)]/30 hover:to-[var(--button-hover)]/30 hover:border-[var(--primary-color)]/60 hover:scale-105 hover:shadow-lg hover:shadow-[var(--primary-color)]/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						📱 Mobile Apps
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-[var(--primary-color)]/20 to-[var(--button-hover)]/20 border border-[var(--primary-color)]/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-[var(--primary-color)]/30 hover:to-[var(--button-hover)]/30 hover:border-[var(--primary-color)]/60 hover:scale-105 hover:shadow-lg hover:shadow-[var(--primary-color)]/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🎨 UI/UX Design
					</span>
				</div>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/contact" class="button_primary text-lg font-bold px-8 py-3">
						Get In Touch
					</a>
					<a href={import.meta.env.BASE_URL + "project"} class="button_secondary text-lg font-bold px-8 py-3">
						View Projects
					</a>
				</div>
			</div>
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20">
				<a class="animate-bounce" href="#about" aria-label="Scroll to about section">
					<svg class="h-8 w-8 text-text-secondary hover:text-primary-color transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
					</svg>
					<span class="sr-only">Scroll to about section</span>
				</a>
			</div>
		</section>

		<!-- Profile Guide Section -->
		<section class="py-12 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-blue-500/10 to-green-500/10 border-y border-gray-700/50">
			<div class="container mx-auto max-w-4xl">
				<div class="flex flex-col md:flex-row items-center justify-between gap-8">
					<div class="flex-1">
						<h3 class="text-xl font-semibold mb-3 flex items-center gap-2">
							<svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
							</svg>
							Customize Your Experience
						</h3>
						<p class="text-text-secondary mb-4">
							First time here? Look for the <span class="font-semibold text-white">profile icon button</span> in the bottom-left corner to switch between two different portfolio profiles tailored for your role.
						</p>
						<div class="flex flex-wrap gap-4">
							<div class="flex items-center gap-2">
								<span class="px-3 py-1 bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded-full text-sm font-medium">IT Support Profile</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="px-3 py-1 bg-green-500/20 text-green-400 border border-green-500/30 rounded-full text-sm font-medium">Developer Profile</span>
							</div>
						</div>
					</div>
					<div class="flex-shrink-0">
						<div class="w-20 h-20 bg-gradient-to-br from-gray-700 to-gray-800 rounded-full border-2 border-dashed border-gray-600 flex items-center justify-center relative group">
							<svg class="w-10 h-10 text-gray-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"></path>
							</svg>
							<div class="absolute -top-2 -right-2 w-6 h-6 bg-blue-500 rounded-full border-2 border-gray-900 flex items-center justify-center">
								<svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
									<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L9 4.414V16a1 1 0 102 0V4.414l6.293 6.293a1 1 0 001.414-1.414l-7-7z"></path>
								</svg>
							</div>
						</div>
						<p class="text-xs text-gray-500 text-center mt-2">Profile Button</p>
					</div>
				</div>
			</div>
		</section>

		<section id="about" class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center fade-in-scroll">
					<div class="w-full aspect-square max-w-md mx-auto lg:mx-0 rounded-lg bg-center bg-no-repeat bg-cover" style={`background-image: url("${import.meta.env.BASE_URL}assets/profile.webp")`}></div>
					<div class="text-left">
						<h2 class="text-3xl font-bold mb-4">About Me</h2>
						<p class="text-lg text-text-secondary leading-relaxed mb-6">
							I am an IT undergraduate at Universiti Tun Hussein Onn Malaysia with hands-on experience in technical support, leadership, and multimedia content creation. I thrive on solving IT problems, optimizing systems, and delivering creative solutions using technology.
						</p>
						<a href={import.meta.env.BASE_URL + "about"} class="button_primary">More About Me</a>
					</div>
				</div>
			</div>
		</section>

		<!-- What I Do Section -->
		<section id="what-i-do" class="py-24 px-4 sm:px-6 lg:px-8 bg-[var(--accent-color)]/20">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 fade-in-scroll">What I Do</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<div class="card text-center fade-in-scroll">
						<div class="mb-4">
							<svg class="w-12 h-12 mx-auto text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"></path></svg>
						</div>
						<h3 class="text-xl font-semibold mb-2">IT Support</h3>
						<p class="text-text-secondary">Providing technical assistance and troubleshooting to resolve hardware and software issues.</p>
					</div>
					<div class="card text-center fade-in-scroll">
						<div class="mb-4">
							<svg class="w-12 h-12 mx-auto text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path></svg>
						</div>
						<h3 class="text-xl font-semibold mb-2">Networking</h3>
						<p class="text-text-secondary">Configuring and maintaining network infrastructure to ensure seamless connectivity.</p>
					</div>
					<div class="card text-center fade-in-scroll">
						<div class="mb-4">
							<svg class="w-12 h-12 mx-auto text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
						</div>
						<h3 class="text-xl font-semibold mb-2">Multimedia</h3>
						<p class="text-text-secondary">Creating engaging visual content, including graphics, videos, and other digital media.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Experience Snapshot Section -->
		<section id="experience-snapshot" class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 fade-in-scroll">Experience Snapshot</h2>
				<div class="relative max-w-3xl mx-auto">
					<div class="timeline-line"></div>
					<div class="timeline-item fade-in-scroll">
						<div class="timeline-marker"></div>
						<div class="ml-4">
							<h3 class="text-xl font-semibold">Vice President Club, Information Technology Club</h3>
							<p class="text-text-secondary mb-2">Universiti Tun Hussein Onn Malaysia | December 2023 - January 2025</p>
						</div>
					</div>
					<div class="timeline-item fade-in-scroll">
						<div class="timeline-marker"></div>
						<div class="ml-4">
							<h3 class="text-xl font-semibold">Facilitator Food Department Orientation Day (MHS)</h3>
							<p class="text-text-secondary mb-2">Universiti Tun Hussein Onn Malaysia | October 2024 - October 2024 (2 Week)</p>
						</div>
					</div>
				</div>
				<div class="text-center mt-12 fade-in-scroll">
					<a href={import.meta.env.BASE_URL + "experience"} class="button_secondary">View Full Timeline</a>
				</div>
			</div>
		</section>

		<section id="projects" class="py-24 px-4 sm:px-6 lg:px-8 bg-[var(--accent-color)]/20">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 fade-in-scroll">Featured Projects</h2>
				<div class="projects-grid">
					<!-- Project: Rumah Tenang -->
					<div class="project-card fade-in-scroll" data-category="landing-page">
						<div class="project-image-container">
							<img src={import.meta.env.BASE_URL + "assets/rumah_tenang.webp"} alt="Rumah Tenang Project" class="w-full h-full object-contain rounded-lg" width="368" height="178" loading="lazy">
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Rumah Tenang - Your Authentic Malaysian Escape</h3>
								<div class="project-badges">
									<span class="project-badge landing-page">Landing Page</span>
									<div class="skills-tags">
										<span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">HTML</span>
										<span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">CSS</span>
										<span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">JS</span>
									</div>
								</div>
							</div>
							<p class="project-description mb-4">A responsive landing page for a Malaysian homestay business targeting foreign tourists and vacationers. Features an interactive image gallery showcasing local attractions and a contact form for booking inquiries.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/rumah-tenang"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

					<!-- Project: Nasi Lemak Burger -->
					<div class="project-card fade-in-scroll" data-category="landing-page">
						<div class="project-image-container">
							<img src={import.meta.env.BASE_URL + "assets/burger.webp"} alt="Nasi Lemak Burger Project" class="w-full h-full object-contain rounded-lg" width="354" height="179" loading="lazy">
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Nasi Lemak Burger</h3>
								<div class="project-badges">
									<span class="project-badge landing-page">Landing Page</span>
									<div class="skills-tags">
										<span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">HTML</span>
										<span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">CSS</span>
										<span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">JS</span>
									</div>
								</div>
							</div>
							<p class="project-description mb-4">A dynamic promotional landing page featuring a countdown timer that resets on each visit, creating urgency for limited-time food promotions. Designed to drive immediate customer action and boost conversions.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/nasi-lemak-burger"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

					<!-- Project: Healthy Food App -->
					<div class="project-card fade-in-scroll" data-category="mobile">
						<div class="project-image-container">
							<div class="mobile-mockup">
								<div class="text-center text-xs font-bold text-white mb-2">Healthy Food App</div>
								<div class="flex-grow bg-gray-700 rounded-lg p-2 text-xs text-gray-300 overflow-hidden">
									<p class="font-semibold mb-1">✨ Features</p>
									<ul class="list-disc list-inside text-gray-400">
										<li>Meal Discovery</li>
										<li>Nutritional Tracking</li>
										<li>Shopping Cart</li>
										<li>Offline Access</li>
									</ul>
								</div>
								<div class="flex justify-center items-center mt-2">
									<svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
								</div>
							</div>
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Healthy Food App</h3>
								<div class="project-badges">
									<span class="project-badge mobile">Mobile App</span>
									<div class="skills-tags">
										<span class="px-2 py-1 text-xs font-semibold bg-blue-600/20 text-blue-400 border border-blue-600/30 rounded">Flutter</span>
										<span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">Dart</span>
										<span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Firebase</span>
									</div>
								</div>
							</div>
							<p class="project-description mb-4">A comprehensive mobile app for healthy meal planning featuring recipe generation, local shop delivery integration, and premium subscription plans for personalized diet meal plans.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/healthy-food-app"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

					<!-- Project: Hotel Management System -->
					<div class="project-card fade-in-scroll" data-category="c++">
						<div class="project-image-container">
							<div class="terminal-mockup">
								<div class="flex items-center pb-1 mb-1 border-b border-gray-700">
									<div class="w-3 h-3 bg-red-500 rounded-full mr-1.5"></div>
									<div class="w-3 h-3 bg-yellow-500 rounded-full mr-1.5"></div>
									<div class="w-3 h-3 bg-green-500 rounded-full"></div>
								</div>
								<div class="flex-grow overflow-hidden">
									<p class="text-gray-400">> g++ main.cpp -o hotel_manager</p>
									<p class="text-gray-400">> ./hotel_manager</p>
									<p>Hotel Management System</p>
									<p>1. Add Room</p>
									<p>2. Book Room</p>
									<p>3. Checkout Room</p>
									<p class="text-green-400 animate-pulse">> Enter choice: _</p>
								</div>
							</div>
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Hotel Management System</h3>
								<div class="project-badges">
									<span class="project-badge cpp">C++</span>
									<div class="skills-tags">
										<span class="px-2 py-1 text-xs font-semibold bg-blue-700/20 text-blue-400 border border-blue-700/30 rounded">C++</span>
										<span class="px-2 py-1 text-xs font-semibold bg-purple-600/20 text-purple-400 border border-purple-600/30 rounded">OOP</span>
										<span class="px-2 py-1 text-xs font-semibold bg-gray-500/20 text-gray-400 border border-gray-500/30 rounded">CLI</span>
							</div>
							</div>
							<p class="project-description mb-4">A complete command-line hotel management system implementing all essential booking flow operations using Object-Oriented Programming principles for robust and scalable architecture.</p>
							<div class="project-actions">
								<a href={import.meta.env.BASE_URL + "projects/hotel-management-system"} class="project-action-button primary">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
									</svg>
									View Project
								</a>
							</div>
						</div>
					</div>

					<!-- More Projects Card -->
					<div class="more-projects-card fade-in-scroll">
						<a href={import.meta.env.BASE_URL + "project"}>
							<h3>View All Projects</h3>
							<p class="text-text-secondary">Explore the full gallery of my work.</p>
							<div class="arrow">&rarr;</div>
						</a>
					</div>
				</div>
				<div class="text-center mt-12 fade-in-scroll">
					<a href={import.meta.env.BASE_URL + "project"} class="button_secondary">View All Projects</a>
				</div>
			</div>
		</section>

		<section id="contact-cta" class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto text-center fade-in-scroll">
				<h2 class="text-3xl font-bold mb-4">Let's Connect</h2>
				<p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">I'm always open to discussing new projects, creative ideas, or opportunities to be part of an amazing team. Feel free to reach out.</p>
				<a href="/portfolio/contact" class="button_primary text-lg font-bold px-8 py-3">
					Get In Touch
				</a>
			</div>
		</section>

		<!-- Back to Top Button -->
		<button id="back-to-top" class="fixed bottom-8 right-8 bg-[var(--primary-color)] text-white p-3 rounded-full shadow-lg hover:bg-[var(--button-hover)] transition-all duration-300 opacity-0 invisible hover:scale-110 z-50">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
			</svg>
		</button>
	</main>
</Layout>

<script>
	// Back to Top Button Functionality
	document.addEventListener('DOMContentLoaded', function() {
		const backToTopButton = document.getElementById('back-to-top');
		
		// Show/hide button based on scroll position
		window.addEventListener('scroll', function() {
			if (window.pageYOffset > 300) {
				backToTopButton.classList.remove('opacity-0', 'invisible');
				backToTopButton.classList.add('opacity-100', 'visible');
			} else {
				backToTopButton.classList.add('opacity-0', 'invisible');
				backToTopButton.classList.remove('opacity-100', 'visible');
			}
		});
		
		// Smooth scroll to top when clicked
		backToTopButton.addEventListener('click', function() {
			window.scrollTo({
				top: 0,
				behavior: 'smooth'
			});
		});

	});

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Choose Your Profile - Noor Azami" description="Select your role to view the customized portfolio profile for IT Support or Software Developer positions.">
    <Header />
    <main class="pt-16">
        <section class="py-32 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto max-w-4xl">
                <!-- Title Section -->
                <div class="text-center mb-16 fade-in-scroll">
                    <h1 class="text-4xl md:text-5xl font-bold mb-4">Choose Your Profile</h1>
                    <p class="text-xl text-text-secondary max-w-2xl mx-auto">Select the role that best matches your needs to view a customized portfolio experience.</p>
                </div>

                <!-- Profile Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- IT Support Profile Card -->
                    <a href={import.meta.env.BASE_URL + "profile/it-support"} class="group card-link">
                        <div class="card profile-card fade-in-scroll">
                            <div class="profile-card-header">
                                <div class="profile-icon it-support-icon">
                                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20m0 0l-.75 3M9 20H5m15-5h-3.75M15 5h-3m0 0h-3m3 0V2m0 3H6m0 0h-.75m.75 0l-.75-3M19 11l3-.75m0 0l.75-3M22 11h-3m0 0v3m0-3V8"></path>
                                    </svg>
                                </div>
                                <h2 class="text-2xl font-bold mt-4">IT Support Professional</h2>
                            </div>
                            
                            <div class="profile-card-content">
                                <p class="text-text-secondary mb-6">Explore a portfolio optimized for IT support roles, featuring:</p>
                                
                                <ul class="space-y-3">
                                    <li class="flex items-start gap-3">
                                        <span class="text-blue-400 font-bold">✓</span>
                                        <span class="text-text-secondary">IT Support & Troubleshooting expertise</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-blue-400 font-bold">✓</span>
                                        <span class="text-text-secondary">Technical documentation projects</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-blue-400 font-bold">✓</span>
                                        <span class="text-text-secondary">System administration & networking</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-blue-400 font-bold">✓</span>
                                        <span class="text-text-secondary">Infrastructure & hardware knowledge</span>
                                    </li>
                                </ul>
                            </div>

                            <div class="profile-card-footer">
                                <span class="inline-flex items-center gap-2 text-blue-400 font-semibold group-hover:translate-x-2 transition-transform">
                                    View IT Support Profile
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                    </a>

                    <!-- Software Developer Profile Card -->
                    <a href={import.meta.env.BASE_URL + "profile/software-developer"} class="group card-link">
                        <div class="card profile-card fade-in-scroll">
                            <div class="profile-card-header">
                                <div class="profile-icon software-icon">
                                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                                    </svg>
                                </div>
                                <h2 class="text-2xl font-bold mt-4">Software Developer</h2>
                            </div>
                            
                            <div class="profile-card-content">
                                <p class="text-text-secondary mb-6">Explore a portfolio optimized for development roles, featuring:</p>
                                
                                <ul class="space-y-3">
                                    <li class="flex items-start gap-3">
                                        <span class="text-green-400 font-bold">✓</span>
                                        <span class="text-text-secondary">Full-stack development projects</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-green-400 font-bold">✓</span>
                                        <span class="text-text-secondary">Mobile app development experience</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-green-400 font-bold">✓</span>
                                        <span class="text-text-secondary">Programming languages & frameworks</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-green-400 font-bold">✓</span>
                                        <span class="text-text-secondary">Technical skills & code samples</span>
                                    </li>
                                </ul>
                            </div>

                            <div class="profile-card-footer">
                                <span class="inline-flex items-center gap-2 text-green-400 font-semibold group-hover:translate-x-2 transition-transform">
                                    View Developer Profile
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Info Section -->
                <div class="mt-16 p-8 bg-gray-800/30 border border-gray-700 rounded-lg fade-in-scroll">
                    <h3 class="text-lg font-semibold mb-4">Why Role-Based Profiles?</h3>
                    <p class="text-text-secondary mb-4">
                        Each profile is tailored to highlight the most relevant skills and projects for that specific role. Recruiters can quickly see your expertise in their area of interest, making it easier to assess fit for their position.
                    </p>
                    <p class="text-text-secondary">
                        Both profiles showcase the same person - you! - just organized differently to emphasize relevant experience and skills.
                    </p>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .card-link {
        text-decoration: none;
        display: block;
        transition: all 0.3s ease;
    }

    .profile-card {
        display: flex;
        flex-direction: column;
        height: 100%;
        cursor: pointer;
        overflow: hidden;
        position: relative;
    }

    .profile-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
        transform: scaleX(0);
        transition: transform 0.3s ease;
    }

    .card-link:hover .profile-card::before {
        transform: scaleX(1);
    }

    .profile-card-header {
        text-align: center;
        padding: 2rem 0;
    }

    .profile-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        border-radius: 12px;
        margin: 0 auto;
    }

    .profile-icon.it-support-icon {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(59, 130, 246, 0.1) 100%);
        border: 2px solid rgba(59, 130, 246, 0.3);
        color: #60a5fa;
    }

    .profile-icon.software-icon {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(34, 197, 94, 0.1) 100%);
        border: 2px solid rgba(34, 197, 94, 0.3);
        color: #4ade80;
    }

    .profile-card-content {
        flex-grow: 1;
        padding: 0 1.5rem 1.5rem;
    }

    .profile-card-footer {
        padding: 0 1.5rem 1.5rem;
    }
</style>

---
import Layout from '../../layouts/Layout.astro';
import LandingHeader from '../../components/LandingHeader.astro';
---

<Layout title="Case Study: The Nasi Lemak Burger Hype Machine" description="Case study on a promo site for a limited edition food drop.">
    <LandingHeader />
    <main class="pt-16 bg-gray-900 text-white">
        <!-- Hero Section -->
        <section class="py-16 px-4">
            <div class="container mx-auto">
                <img src={import.meta.env.BASE_URL + "assets/burger.webp"} alt="Nasi Lemak Burger Showcase" class="rounded-lg shadow-2xl mx-auto w-full max-w-5xl animate-on-scroll fade-in-up">
                <div class="text-center mt-12 animate-on-scroll fade-in-up animation-delay-200">
                    <p class="text-sm font-bold uppercase tracking-widest text-[var(--primary-color)]">CASE STUDY: NASI LEMAK BURGER</p>
                    <h1 class="text-4xl md:text-6xl font-extrabold my-4 leading-tight">
                        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-teal-300">The Hype Machine for a Limited Drop</span>
                    </h1>
                    <p class="text-lg md:text-xl max-w-3xl mx-auto text-gray-300">How a dynamic promo page created legit urgency and boosted sales.</p>
                </div>
            </div>
        </section>

        <section class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto">
                <!-- Main Content Layout -->
                <div class="grid lg:grid-cols-12 gap-12">
                    <!-- Sidebar -->
                    <aside class="lg:col-span-4 lg:order-2">
                        <div class="sticky top-28 bg-[var(--card-background)] border border-[var(--border-color)] rounded-lg p-6 shadow-lg animate-on-scroll fade-in-right">
                            <h3 class="text-xl font-bold mb-4 border-b border-[var(--border-color)] pb-3 text-gray-100">Project Deets</h3>
                            <ul class="space-y-4 text-text-secondary">
                                <li class="flex flex-col items-start">
                                    <strong class="font-semibold text-white mb-1">The Collab:</strong> 
                                    <span>Local Burger Stall</span>
                                </li>
                                <li class="flex flex-col items-start">
                                    <strong class="font-semibold text-white mb-1">The Build:</strong> 
                                    <span>Landing Page Development</span>
                                </li>
                                <li class="flex flex-col items-start">
                                    <strong class="font-semibold text-white mb-1">The Stack:</strong>
                                    <div class="flex gap-2 mt-1">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">HTML</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">CSS</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">JS</span>
                                    </div>
                                </li>
                            </ul>
                            <div class="mt-6 pt-4 border-t border-[var(--border-color)]">
                                <a href="https://amiqt.github.io/landing_page_2/" class="button_secondary w-full" target="_blank" rel="noopener noreferrer">Live Preview</a>
                            </div>
                        </div>
                    </aside>

                    <!-- Main Content -->
                    <div class="lg:col-span-8 lg:order-1">
                        <!-- The Challenge -->
                        <div class="mb-16 animate-on-scroll fade-in-up">
                            <h2 class="text-3xl font-bold mb-4 flex items-center text-gray-100"><svg class="w-8 h-8 mr-3 text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.636-6.364l.707.707M12 21v-1m-6.364-1.636l.707-.707"></path></svg> The Problem</h2>
                            <p class="text-text-secondary text-lg leading-relaxed">
                                The client had a killer product drop but social media posts weren't creating enough hype. They needed a way to build real urgency and drive immediate orders.
                            </p>
                        </div>

                        <!-- The Solution -->
                        <div class="mb-12 animate-on-scroll fade-in-up animation-delay-200">
                            <h2 class="text-3xl font-bold mb-4 flex items-center text-gray-100"><svg class="w-8 h-8 mr-3 text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> The Fix</h2>
                            <p class="text-text-secondary text-lg leading-relaxed">
                                I built a dynamic promo page with a countdown timer that resets on every visit. This created a constant FOMO effect, pushing customers to order fast. The design was clean, with big product pics and a straight shot to the order link.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- The Results -->
                <div class="mt-16">
                    <h2 class="text-3xl font-bold mb-8 text-center flex items-center justify-center animate-on-scroll fade-in-up text-gray-100"><svg class="w-8 h-8 mr-3 text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg> The Wins</h2>
                    <div class="grid md:grid-cols-3 gap-8 text-center">
                        <div class="card p-8 bg-gray-800/50 border border-gray-700 animate-on-scroll fade-in-up">
                            <p class="text-5xl font-bold text-[var(--primary-color)] stat-number" data-target="70">0</p>
                            <p class="mt-2 text-text-secondary">% Sales Boost</p>
                        </div>
                        <div class="card p-8 bg-gray-800/50 border border-gray-700 animate-on-scroll fade-in-up animation-delay-200">
                            <p class="text-5xl font-bold text-[var(--primary-color)] stat-number" data-target="2">0</p>
                            <p class="mt-2 text-text-secondary">x Customer Action</p>
                        </div>
                        <div class="card p-8 bg-gray-800/50 border border-gray-700 animate-on-scroll fade-in-up animation-delay-400">
                            <p class="text-5xl font-bold text-[var(--primary-color)] stat-number" data-target="100">0</p>
                            <p class="mt-2 text-text-secondary">% Reusable for Future Drops</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
		<section id="cta" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-800 mt-16">
			<div class="container mx-auto text-center animate-on-scroll fade-in-up">
				<h2 class="text-3xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-teal-300">Got a Product to Launch?</h2>
				<p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">Let's talk about how we can build an effective promo campaign for your product.</p>
				<a href="https://wa.me/60138799702" target="_blank" rel="noopener noreferrer" class="button_primary text-lg font-bold px-8 py-3 transform hover:scale-105 transition-transform duration-300">
					Let's Build the Hype
				</a>
			</div>
		</section>
    </main>
</Layout>

<style>
    .animation-delay-200 { animation-delay: 0.2s; }
    .animation-delay-400 { animation-delay: 0.4s; }
    .animate-on-scroll { opacity: 0; transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
    .fade-in-up { transform: translateY(30px); }
    .fade-in-right { transform: translateX(-30px); }
    .animate-on-scroll.is-visible { opacity: 1; transform: translateY(0) translateX(0); }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    const statNumbers = entry.target.querySelectorAll('.stat-number');
                    if (statNumbers.length > 0) {
                        observer.unobserve(entry.target);
                        statNumbers.forEach(statNumber => {
                            if (statNumber.dataset.counted) return;
                            statNumber.dataset.counted = true;
                            const target = +statNumber.getAttribute('data-target');
                            let current = 0;
                            const increment = target / 100;
                            const updateCounter = () => {
                                if (current < target) {
                                    current += increment;
                                    statNumber.innerText = Math.ceil(current).toString();
                                } else {
                                    statNumber.innerText = target.toString();
                                }
                            };
                            updateCounter();
                        });
                    } else {
                        observer.unobserve(entry.target);
                    }
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    });
</script>
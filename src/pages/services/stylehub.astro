---
import Layout from '../../layouts/Layout.astro';
import LandingHeader from '../../components/LandingHeader.astro';
---

<Layout title="Case Study: Building a Full-Stack E-comm Platform" description="A case study on building a fashion e-commerce platform with React, Node.js, and PostgreSQL.">
    <LandingHeader />
    <main class="pt-16 bg-gray-900 text-white">
        <!-- Hero Section -->
        <section class="py-16 px-4">
            <div class="container mx-auto">
                <div class="w-full max-w-5xl mx-auto h-96 bg-gradient-to-br from-pink-500/20 to-purple-500/20 rounded-lg shadow-2xl border border-pink-500/30 flex items-center justify-center animate-on-scroll fade-in-up">
                    <div class="text-center">
                        <div class="w-24 h-24 bg-pink-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-12 h-12 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </div>
                        <h3 class="text-3xl font-bold text-pink-400 mb-2">StyleHub</h3>
                    </div>
                </div>
                <div class="text-center mt-12 animate-on-scroll fade-in-up animation-delay-200">
                    <p class="text-sm font-bold uppercase tracking-widest text-[var(--primary-color)]">CASE STUDY: STYLEHUB</p>
                    <h1 class="text-4xl md:text-6xl font-extrabold my-4 leading-tight">
                        <span class="bg-clip-text text-transparent bg-gradient-to-r from-pink-400 to-purple-400">Building a Full-Stack E-comm Platform</span>
                    </h1>
                    <p class="text-lg md:text-xl max-w-3xl mx-auto text-gray-300">From zero to a complete fashion e-commerce experience, built with a modern stack.</p>
                </div>
            </div>
        </section>

        <section class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto">
                <!-- Main Content Layout -->
                <div class="grid lg:grid-cols-12 gap-12">
                    <!-- Sidebar -->
                    <aside class="lg:col-span-4 lg:order-2">
                        <div class="sticky top-28 bg-[var(--card-background)] border border-[var(--border-color)] rounded-lg p-6 shadow-lg animate-on-scroll fade-in-right">
                            <h3 class="text-xl font-bold mb-4 border-b border-[var(--border-color)] pb-3 text-gray-100">Project Deets</h3>
                            <ul class="space-y-4 text-text-secondary">
                                <li class="flex flex-col items-start">
                                    <strong class="font-semibold text-white mb-1">The Collab:</strong> 
                                    <span>Personal Project</span>
                                </li>
                                <li class="flex flex-col items-start">
                                    <strong class="font-semibold text-white mb-1">The Build:</strong> 
                                    <span>Full-Stack Development</span>
                                </li>
                                <li class="flex flex-col items-start">
                                    <strong class="font-semibold text-white mb-1">The Stack:</strong>
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">React</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Node.js</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">PostgreSQL</span>
                                    </div>
                                </li>
                            </ul>
                            <div class="mt-6 pt-4 border-t border-[var(--border-color)]">
                                <a href="https://e-commerce-coral-five-81.vercel.app/" class="button_secondary w-full" target="_blank" rel="noopener noreferrer">Live Preview</a>
                            </div>
                        </div>
                    </aside>

                    <!-- Main Content -->
                    <div class="lg:col-span-8 lg:order-1">
                        <!-- The Challenge -->
                        <div class="mb-16 animate-on-scroll fade-in-up">
                            <h2 class="text-3xl font-bold mb-4 flex items-center text-gray-100"><svg class="w-8 h-8 mr-3 text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.636-6.364l.707.707M12 21v-1m-6.364-1.636l.707-.707"></path></svg> The Problem</h2>
                            <p class="text-text-secondary text-lg leading-relaxed">
                                The challenge was to build a complete e-commerce platform from scratch—covering everything from the product display to secure payments, while making sure it's scalable and responsive on all devices.
                            </p>
                        </div>

                        <!-- The Solution -->
                        <div class="mb-12 animate-on-scroll fade-in-up animation-delay-200">
                            <h2 class="text-3xl font-bold mb-4 flex items-center text-gray-100"><svg class="w-8 h-8 mr-3 text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> The Fix</h2>
                            <p class="text-text-secondary text-lg leading-relaxed">
                                I architected a full-stack solution: a slick React frontend for an interactive UI, a solid Node.js (Express) API backend, and a PostgreSQL database for data management. I implemented key features like JWT authentication, cart management, and Stripe integration to create a seamless shopping vibe.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- The Results -->
                <div class="mt-16">
                    <h2 class="text-3xl font-bold mb-8 text-center flex items-center justify-center animate-on-scroll fade-in-up text-gray-100"><svg class="w-8 h-8 mr-3 text-[var(--primary-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg> The Wins</h2>
                    <div class="grid md:grid-cols-3 gap-8 text-center">
                        <div class="card p-8 bg-gray-800/50 border border-gray-700 animate-on-scroll fade-in-up">
                            <p class="text-5xl font-bold text-[var(--primary-color)] stat-number" data-target="100">0</p>
                            <p class="mt-2 text-text-secondary">% Full E-comm Functionality</p>
                        </div>
                        <div class="card p-8 bg-gray-800/50 border border-gray-700 animate-on-scroll fade-in-up animation-delay-200">
                            <p class="text-5xl font-bold text-[var(--primary-color)] stat-number" data-target="15">0</p>
                            <p class="mt-2 text-text-secondary">+ API Endpoints Built</p>
                        </div>
                        <div class="card p-8 bg-gray-800/50 border border-gray-700 animate-on-scroll fade-in-up animation-delay-400">
                            <p class="text-5xl font-bold text-[var(--primary-color)] stat-number" data-target="1">0</p>
                            <p class="mt-2 text-text-secondary">Scalable Platform</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
		<section id="cta" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-800 mt-16">
			<div class="container mx-auto text-center animate-on-scroll fade-in-up">
				<h2 class="text-3xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-pink-400 to-purple-400">Ready to Build Your Platform?</h2>
				<p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">Let's talk about how we can bring your web app idea to life.</p>
				<a href="https://wa.me/60138799702" target="_blank" rel="noopener noreferrer" class="button_primary text-lg font-bold px-8 py-3 transform hover:scale-105 transition-transform duration-300">
					Let's Architect It
				</a>
			</div>
		</section>
    </main>
</Layout>

<style>
    .animation-delay-200 { animation-delay: 0.2s; }
    .animation-delay-400 { animation-delay: 0.4s; }
    .animate-on-scroll { opacity: 0; transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
    .fade-in-up { transform: translateY(30px); }
    .fade-in-right { transform: translateX(-30px); }
    .animate-on-scroll.is-visible { opacity: 1; transform: translateY(0) translateX(0); }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    const statNumbers = entry.target.querySelectorAll('.stat-number');
                    if (statNumbers.length > 0) {
                        observer.unobserve(entry.target);
                        statNumbers.forEach(statNumber => {
                            if (statNumber.dataset.counted) return;
                            statNumber.dataset.counted = true;
                            const target = +statNumber.getAttribute('data-target');
                            let current = 0;
                            const increment = target / 100;
                            const updateCounter = () => {
                                if (current < target) {
                                    current += increment;
                                    statNumber.innerText = Math.ceil(current).toString();
                                    requestAnimationFrame(updateCounter);
                                } else {
                                    statNumber.innerText = target.toString();
                                }
                            };
                            updateCounter();
                        });
                    } else {
                        observer.unobserve(entry.target);
                    }
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    });
</script>
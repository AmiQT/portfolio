---
import Layout from '../layouts/Layout.astro';
import LandingHeader from '../components/LandingHeader.astro';
---

<Layout title="Web Services | Noorayuni" description="Servis web dev custom dengan sentuhan AI untuk projek gempak.">
	<LandingHeader />
	<main class="pt-16 bg-gray-900">

		<!-- Hero Section -->
		<section class="relative flex items-center justify-center text-center px-4 py-24 sm:px-6 lg:px-8 overflow-hidden hero-grid-bg">
			<div class="z-10 animate-on-scroll fade-in-up">
				<h1 class="text-5xl md:text-6xl font-bold mb-4 text-white">Ada Idea Gempak? Jom Realisasikannya.</h1>
				<p class="text-xl md:text-2xl mb-8 text-gray-300 max-w-3xl mx-auto">Custom web builds dengan sentuhan AI magic. Bukan web biasa-biasa.</p>
				<a href="#cta" class="button_primary text-lg font-bold px-8 py-3">
					Let's Collab
				</a>
			</div>
		</section>

        <!-- Detailed Services Section -->
        <section class="py-24 px-4 bg-gray-900">
            <div class="container mx-auto">
                <div class="text-center mb-12 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-bold text-white">What I Cook Up 🍳</h2>
                    <p class="text-text-secondary mt-2">Dari landing page simple, ke platform e-comm yang kompleks.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="card-interactive p-8 text-center animate-on-scroll fade-in-up">
                        <div class="flex items-center justify-center w-16 h-16 mb-6 bg-green-500/10 rounded-lg border border-green-500/20 mx-auto"><svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></div>
                        <h3 class="text-xl font-semibold mb-2 text-white">E-commerce Store</h3>
                        <p class="text-text-secondary">Setup kedai online yang legit. Product management, payment gateway, semua settle.</p>
                    </div>
                    <div class="card-interactive p-8 text-center animate-on-scroll fade-in-up animation-delay-200">
                        <div class="flex items-center justify-center w-16 h-16 mb-6 bg-blue-500/10 rounded-lg border border-blue-500/20 mx-auto"><svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg></div>
                        <h3 class="text-xl font-semibold mb-2 text-white">Booking System</h3>
                        <p class="text-text-secondary">Untuk hotel, servis, atau apa-apa yang perlukan slot booking. Automate your hustle.</p>
                    </div>
                    <div class="card-interactive p-8 text-center animate-on-scroll fade-in-up animation-delay-400">
                        <div class="flex items-center justify-center w-16 h-16 mb-6 bg-purple-500/10 rounded-lg border border-purple-500/20 mx-auto"><svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg></div>
                        <h3 class="text-xl font-semibold mb-2 text-white">Corporate Site</h3>
                        <p class="text-text-secondary">Bagi brand atau syarikat kau nampak pro dan established. First impression matters.</p>
                    </div>
                </div>
            </div>
        </section>

		<!-- Why Choose Us Section -->
		<section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-800/30">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 animate-on-scroll fade-in-up text-white">Why Collab With Me?</h2>
				<div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
					<div class="card-interactive text-left p-8 animate-on-scroll fade-in-up">
                        <div class="flex items-center justify-center w-16 h-16 mb-6 bg-blue-500/10 rounded-lg border border-blue-500/20">
                            <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                        </div>
						<h3 class="text-2xl font-semibold mb-4 text-gray-100">No Templates, Just Pure Code</h3>
						<p class="text-text-secondary">Setiap bisnes ada vibe tersendiri. Aku tak pakai templat. Aku build dari zero, khas untuk brand kau.</p>
					</div>
					<div class="card-interactive text-left p-8 animate-on-scroll fade-in-up animation-delay-200">
                        <div class="flex items-center justify-center w-16 h-16 mb-6 bg-purple-500/10 rounded-lg border border-purple-500/20">
                            <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M12 6V3m0 18v-3M5.636 5.636l-1.414-1.414M19.778 19.778l-1.414-1.414M4.222 19.778l1.414-1.414M18.364 5.636l1.414-1.414"></path></svg>
                        </div>
						<h3 class="text-2xl font-semibold mb-4 text-gray-100">AI-Powered Features</h3>
						<p class="text-text-secondary">Let's add some brains. Smart chatbots, product recommendations, data insights. Boleh je.</p>
					</div>
				</div>
			</div>
		</section>

        <!-- Tech Stack Showcase -->
        <section class="py-24 px-4 bg-gray-900">
            <div class="container mx-auto text-center">
                <h2 class="text-3xl font-bold mb-4 text-white animate-on-scroll fade-in-up">My Tech Stack 🤘</h2>
                <p class="text-text-secondary mb-12 max-w-2xl mx-auto animate-on-scroll fade-in-up animation-delay-200">The tools I use to build fast, secure, and scalable web apps.</p>
                <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-6 max-w-4xl mx-auto animate-on-scroll fade-in-up animation-delay-400">
                    <div class="text-gray-400 font-semibold flex items-center gap-2"><svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624C13.666 10.618 15.027 12 18.001 12c3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C16.337 6.182 14.976 4.8 12.001 4.8zm-6 7.2c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624 1.177 1.194 2.538 2.576 5.512 2.576 3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C10.337 13.382 8.976 12 6.001 12z"></path></svg>Tailwind CSS</div>
                    <div class="text-gray-400 font-semibold flex items-center gap-2"><svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"></path></svg>PostgreSQL</div>
                    <div class="text-gray-400 font-semibold flex items-center gap-2"><svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M9 3.011h6v1.98H9zM12 21a9 9 0 110-18 9 9 0 010 18zm0-2a7 7 0 100-14 7 7 0 000 14zm-2-6h4v-2h-4v2z"></path></svg>Node.js</div>
                    <div class="text-gray-400 font-semibold flex items-center gap-2"><svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M11.999 2.003c-5.52 0-9.998 4.48-9.998 10c0 4.33 2.75 8.01 6.5 9.34.47.09.64-.2.64-.45v-1.58c-2.67.58-3.24-1.29-3.24-1.29-.43-1.1-1.05-1.39-1.05-1.39-.86-.58.07-.57.07-.57.95.07 1.45 1 .45 1 .84 1.44 2.21 1.02 2.75.78.09-.61.33-1.02.6-1.26-2.1-.24-4.31-1.05-4.31-4.68 0-1.03.37-1.88 1-2.6-.1-.24-.43-1.23.1-2.56 0 0 .8-.25 2.6.98.75-.21 1.55-.31 2.35-.31s1.6.1 2.35.31c1.8-1.23 2.6-.98 2.6-.98.53 1.33.2 2.32.1 2.56.63.72 1 1.57 1 2.6 0 3.64-2.21 4.44-4.32 4.68.34.29.64.88.64 1.78v2.6c0 .25.17.54.65.45 3.75-1.33 6.5-5.01 6.5-9.34C21.997 6.483 17.519 2.003 11.999 2.003z"></path></svg>Git</div>
                    <div class="text-gray-400 font-semibold flex items-center gap-2"><svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L1 9l4 2.5V18h14v-6.5L23 9z"></path></svg>Astro</div>
                    <div class="text-gray-400 font-semibold flex items-center gap-2"><svg class="w-5 h-5 text-cyan-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 9.5c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5zm0 9c-2.49 0-4.5-2.01-4.5-4.5S9.51 9.5 12 9.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-11C6.48 7.5 2 12 2 12s4.48 4.5 10 4.5 10-4.5 10-4.5S17.52 7.5 12 7.5zm0 9c-2.49 0-4.5-2.01-4.5-4.5S9.51 12 12 12s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5z"></path></svg>React</div>
                </div>
            </div>
        </section>

		<!-- Portfolio Section -->
		<section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-800/30">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-12 animate-on-scroll fade-in-up text-white">Past Projects</h2>
				<div class="projects-grid">
					<!-- Project: Rumah Tenang -->
					<div class="project-card fade-in-scroll" data-category="landing-page">
						<div class="project-image-container">
							<img src={import.meta.env.BASE_URL + "assets/rumah_tenang.webp"} alt="Rumah Tenang Project" class="w-full h-full object-contain rounded-lg" width="368" height="178" loading="lazy">
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Rumah Tenang - Your Authentic Malaysian Escape</h3>
								<div class="project-badges"><span class="project-badge landing-page">Landing Page</span></div>
							</div>
							<p class="project-description mb-4">A responsive landing page for a Malaysian homestay business targeting foreign tourists and vacationers.</p>
							<div class="project-actions"><a href={import.meta.env.BASE_URL + "services/rumah-tenang"} class="project-action-button primary">View Case Study</a></div>
						</div>
					</div>

					<!-- Project: Nasi Lemak Burger -->
					<div class="project-card fade-in-scroll" data-category="landing-page">
						<div class="project-image-container">
							<img src={import.meta.env.BASE_URL + "assets/burger.webp"} alt="Nasi Lemak Burger Project" class="w-full h-full object-contain rounded-lg" width="354" height="179" loading="lazy">
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">Nasi Lemak Burger</h3>
								<div class="project-badges"><span class="project-badge landing-page">Landing Page</span></div>
							</div>
							<p class="project-description mb-4">A dynamic promotional landing page featuring a countdown timer to create urgency for limited-time promotions.</p>
							<div class="project-actions"><a href={import.meta.env.BASE_URL + "services/nasi-lemak-burger"} class="project-action-button primary">View Case Study</a></div>
						</div>
					</div>

                    <!-- Project: StyleHub -->
					<div class="project-card fade-in-scroll" data-category="full-stack">
						<div class="project-image-container flex items-center justify-center bg-gradient-to-br from-pink-500/10 to-purple-500/10">
							<div class="w-24 h-24 bg-pink-500/20 rounded-full flex items-center justify-center">
                                <svg class="w-12 h-12 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                            </div>
						</div>
						<div class="project-card-content">
							<div class="project-header">
								<h3 class="project-title">StyleHub - E-Commerce Platform</h3>
								<div class="project-badges"><span class="project-badge web-development">Full-Stack</span></div>
							</div>
							<p class="project-description mb-4">A complete e-commerce platform with user authentication, product management, and payment processing.</p>
							<div class="project-actions"><a href={import.meta.env.BASE_URL + "services/stylehub"} class="project-action-button primary">View Case Study</a></div>
						</div>
					</div>
				</div>
			</div>
		</section>

        <!-- Testimonials Section -->
        <section class="py-24 px-4 bg-gray-900">
            <div class="container mx-auto">
                <h2 class="text-3xl font-bold text-center mb-12 text-white animate-on-scroll fade-in-up">The Vibe From Past Collabs</h2>
                <div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
                    <div class="bg-gray-800/50 p-8 rounded-lg border border-gray-700 animate-on-scroll fade-in-up">
                        <p class="text-text-secondary italic mb-4">"The whole process was a vibe. The new site isn't just pretty, it's crazy fast! Our traffic and DMs literally blew up."</p>
                        <p class="font-bold text-white">— Founder, Rumah Tenang</p>
                    </div>
                    <div class="bg-gray-800/50 p-8 rounded-lg border border-gray-700 animate-on-scroll fade-in-up animation-delay-200">
                        <p class="text-text-secondary italic mb-4">"Super pro and totally gets our vision. The promo page he built created legit hype and our limited edition burger sold out fast. 10/10 would collab again!"</p>
                        <p class="font-bold text-white">— Owner, Burger Stall</p>
                    </div>
                </div>
            </div>
        </section>

		<!-- Detailed Methodology Section -->
		<section class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto">
				<h2 class="text-3xl font-bold text-center mb-20 animate-on-scroll fade-in-up text-white">The Game Plan: How We'll Build It</h2>
				<div id="timeline-container" class="relative max-w-3xl mx-auto">
					<svg id="timeline-svg" class="absolute top-0 left-0 w-full h-full" preserveAspectRatio="none"><path id="timeline-path" class="timeline-path" d="M 50 0 V 1000" vector-effect="non-scaling-stroke"></path></svg>
					<div class="relative z-10">
                        <div class="timeline-item flex items-start mb-24 animate-on-scroll fade-in-up">
                            <div class="timeline-step-number">1</div>
                            <div class="ml-8">
                                <h3 class="text-xl font-semibold text-gray-100 mb-2">Phase 1: Strategy & Vibe Check</h3>
                                <p class="text-text-secondary mt-1">We'll deep dive into your vision, goals, and target audience. We'll figure out the project's core vibe and create a solid game plan.</p>
                            </div>
                        </div>
                        <div class="timeline-item flex items-start mb-24 animate-on-scroll fade-in-up">
                            <div class="timeline-step-number">2</div>
                            <div class="ml-8">
                                <h3 class="text-xl font-semibold text-gray-100 mb-2">Phase 2: UI/UX & Prototyping</h3>
                                <p class="text-text-secondary mt-1">This is where the magic starts. I'll design wireframes and interactive prototypes so you can see and feel how the site works before we write a single line of code.</p>
                            </div>
                        </div>
                        <div class="timeline-item flex items-start mb-24 animate-on-scroll fade-in-up">
                            <div class="timeline-step-number">3</div>
                            <div class="ml-8">
                                <h3 class="text-xl font-semibold text-gray-100 mb-2">Phase 3: Agile Development</h3>
                                <p class="text-text-secondary mt-1">I'll start coding, building your site in sprints with the latest tech. You'll get regular updates for feedback. No surprises, just progress.</p>
                            </div>
                        </div>
                        <div class="timeline-item flex items-start mb-24 animate-on-scroll fade-in-up">
                            <div class="timeline-step-number">4</div>
                            <div class="ml-8">
                                <h3 class="text-xl font-semibold text-gray-100 mb-2">Phase 4: QA & Launch</h3>
                                <p class="text-text-secondary mt-1">We hunt down bugs, optimize for speed, and make sure everything is solid. Then, we deploy and go live. 🚀</p>
                            </div>
                        </div>
                        <div class="timeline-item flex items-start animate-on-scroll fade-in-up">
                            <div class="timeline-step-number">5</div>
                            <div class="ml-8">
                                <h3 class="text-xl font-semibold text-gray-100 mb-2">Phase 5: Support & Growth</h3>
                                <p class="text-text-secondary mt-1">I won't ghost you after launch. I provide tech support, training, and we can talk about what's next for your digital game.</p>
                            </div>
                        </div>
                    </div>
				</div>
			</div>
		</section>

        <!-- About Me Section -->
        <section class="py-24 px-4 bg-gray-800/30">
            <div class="container mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-center animate-on-scroll fade-in-up">
                    <div class="lg:col-span-1">
                        <img src={import.meta.env.BASE_URL + "assets/profile.webp"} alt="Noor Azami" class="rounded-full shadow-2xl mx-auto w-48 h-48 object-cover">
                    </div>
                    <div class="lg:col-span-2 text-center lg:text-left">
                        <h2 class="text-3xl font-bold mb-4 text-white">The Guy Behind The Code</h2>
                        <p class="text-lg text-text-secondary leading-relaxed">
                            I'm Azami, a web dev who's passionate about turning complex problems into clean, slick websites. I live for that 'aha!' moment when a design comes to life. When I'm not coding, you'll find me exploring new JS frameworks or deep-diving into API docs for fun.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="py-24 px-4 bg-gray-900">
            <div class="container mx-auto max-w-3xl">
                <h2 class="text-3xl font-bold text-center mb-12 text-white animate-on-scroll fade-in-up">Quick Qs (FAQ)</h2>
                <div class="space-y-4 animate-on-scroll fade-in-up">
                    <details class="faq-item group">
                        <summary class="faq-question">How long does a project take?</summary>
                        <p class="faq-answer">Depends on the project's complexity. A simple landing page can take 1-2 weeks. A full-blown e-comm platform might take 1-3 months. We'll lock down a timeline after our initial chat.</p>
                    </details>
                    <details class="faq-item group">
                        <summary class="faq-question">How much will it cost?</summary>
                        <p class="faq-answer">It all depends on the scope. I'll give you a detailed quote after I understand what you need. Hit me up for a free, no-strings-attached consultation.</p>
                    </details>
                    <details class="faq-item group">
                        <summary class="faq-question">Do you provide support after launch?</summary>
                        <p class="faq-answer">For sure. I offer monthly/yearly maintenance packages that include updates, backups, and tech support to keep your site running smooth and secure.</p>
                    </details>
                </div>
            </div>
        </section>

        <!-- Guarantee Section -->
        <section class="py-24 px-4">
            <div class="container mx-auto max-w-4xl">
                <div class="bg-gradient-to-r from-blue-500 to-purple-600 p-8 rounded-lg text-center animate-on-scroll fade-in-up">
                    <h2 class="text-2xl font-bold text-white mb-2">My Promise: 100% Satisfaction</h2>
                    <p class="text-blue-100 max-w-2xl mx-auto">I'm all in on quality. Every project comes with a 30-day post-launch support guarantee. Let's start the conversation, risk-free.</p>
                </div>
            </div>
        </section>

		<!-- CTA Section -->
		<section id="cta" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-800/30">
			<div class="container mx-auto text-center animate-on-scroll fade-in-up">
				<h2 class="text-3xl font-bold mb-4 text-white">Ready to build something legit?</h2>
				<p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">Let's chat about your idea. Free consult, no obligations.</p>
				<a href="https://wa.me/60138799702" target="_blank" rel="noopener noreferrer" class="button_primary text-lg font-bold px-8 py-3">
					Hit Me Up
				</a>
			</div>
		</section>

	</main>
</Layout>

<style>
    .hero-grid-bg { background-color: #111827; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 2rem 2rem; animation: move-grid 20s linear infinite; }
    @keyframes move-grid { from { background-position: 0 0; } to { background-position: 2rem 2rem; } }
    .card-interactive { background-color: var(--card-background); border: 1px solid var(--border-color); border-radius: 0.5rem; transition: transform 0.3s ease, box-shadow 0.3s ease; position: relative; overflow: hidden; }
    .card-interactive:before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at var(--mouse-x) var(--mouse-y), rgba(139, 92, 246, 0.15), transparent 40%); opacity: 0; transition: opacity 0.3s ease; }
    .card-interactive:hover:before { opacity: 1; }
    .card-interactive:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.2), 0 0 15px rgba(139, 92, 246, 0.1); border-color: rgba(139, 92, 246, 0.3); }
    .timeline-path { stroke: var(--border-color); stroke-width: 2; fill: none; stroke-dasharray: 1000; stroke-dashoffset: 1000; transition: stroke-dashoffset 2s ease-in-out; }
    #timeline-container.is-visible .timeline-path { stroke-dashoffset: 0; }
    .timeline-step-number { width: 3rem; height: 3rem; border-radius: 9999px; background-color: var(--accent-color); border: 2px solid var(--border-color); display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.25rem; transition: background-color 0.5s ease, border-color 0.5s ease, transform 0.5s ease; flex-shrink: 0; }
    .timeline-item.is-visible .timeline-step-number { background-color: var(--primary-color); border-color: var(--button-hover); transform: scale(1.1); }
    .animate-on-scroll { opacity: 0; transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
    .fade-in-up { transform: translateY(30px); }
    .animation-delay-200 { animation-delay: 0.2s; }
    .animate-on-scroll.is-visible { opacity: 1; transform: translateY(0); }
    .faq-item { background-color: var(--card-background); border: 1px solid var(--border-color); border-radius: 0.5rem; overflow: hidden; transition: all 0.3s ease; }
    .faq-item:hover { border-color: var(--primary-color); }
    .faq-question { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; font-weight: 600; cursor: pointer; }
    .faq-question::-webkit-details-marker { display: none; }
    .faq-question::after { content: '+'; font-size: 1.5rem; transition: transform 0.3s ease; }
    .faq-item[open] > .faq-question::after { transform: rotate(45deg); }
    .faq-answer { padding: 0 1.5rem 1.5rem; color: var(--text-secondary); }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const interactiveCards = document.querySelectorAll('.card-interactive');
        interactiveCards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);
            });
        });

        const scrollObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    scrollObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.animate-on-scroll').forEach(el => scrollObserver.observe(el));

        const timelineContainer = document.getElementById('timeline-container');
        if (timelineContainer) {
            const timelinePath = document.getElementById('timeline-path');
            const timelineItems = Array.from(timelineContainer.querySelectorAll('.timeline-item'));

            const timelineObserver = new IntersectionObserver((entries) => {
                if (entries[0].isIntersecting) {
                    timelineContainer.classList.add('is-visible');
                    timelineItems.forEach((item, index) => {
                        setTimeout(() => {
                            item.classList.add('is-visible');
                        }, index * 500); // Stagger the animation of items
                    });
                    timelineObserver.unobserve(timelineContainer);
                }
            }, { threshold: 0.4 });

            const path = timelinePath.getBBox();
            timelinePath.setAttribute('d', `M ${path.x + path.width/2} 0 V ${timelineContainer.offsetHeight}`);
            const pathLength = timelinePath.getTotalLength();
            timelinePath.style.strokeDasharray = pathLength;
            timelinePath.style.strokeDashoffset = pathLength;

            timelineObserver.observe(timelineContainer);
        }
    });
</script>

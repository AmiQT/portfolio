---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProfileSelector from '../../components/ProfileSelector.astro';
---

<Layout title="IT Support Professional - Noor Azami" description="IT Support Specialist Portfolio - Technical support, system administration, and infrastructure expertise." canonical="/role-it-support/">
	<Header />
	<ProfileSelector />
	<main class="pt-16">
		<section class="relative flex items-center justify-center h-screen text-center px-4 sm:px-6 lg:px-8 animated-gradient">
			<div class="z-10">
				<div class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-blue-500/20 border border-blue-500/40 rounded-full">
					<span class="w-3 h-3 bg-blue-500 rounded-full animate-pulse"></span>
					<span class="text-blue-400 font-semibold text-sm">IT Support Professional</span>
				</div>
				<h1 class="text-5xl md:text-7xl font-bold mb-4 leading-tight text-white">Noor Azami</h1>
				<p class="text-xl md:text-2xl font-bold mb-6 max-w-4xl mx-auto leading-relaxed">
					Certified IT Support Specialist with expertise in network administration, system troubleshooting, and infrastructure management
				</p>
				<p class="text-lg text-text-secondary mb-8 max-w-3xl mx-auto font-medium">
					<span class="text-white font-semibold">Technical Problem Solver</span> 
					<span class="text-text-secondary mx-2">|</span> 
					<span class="text-text-secondary">Systems Administrator</span>
				</p>
				<div class="flex flex-wrap justify-center gap-4 mb-8">
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-500/20 to-blue-600/20 border border-blue-500/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-blue-500/30 hover:to-blue-600/30 hover:border-blue-500/60 hover:scale-105 hover:shadow-lg hover:shadow-blue-500/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🖥️ System Administration
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-500/20 to-blue-600/20 border border-blue-500/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-blue-500/30 hover:to-blue-600/30 hover:border-blue-500/60 hover:scale-105 hover:shadow-lg hover:shadow-blue-500/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🌐 Network Management
					</span>
					<span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-500/20 to-blue-600/20 border border-blue-500/40 rounded-full text-sm font-medium hover:bg-gradient-to-r hover:from-blue-500/30 hover:to-blue-600/30 hover:border-blue-500/60 hover:scale-105 hover:shadow-lg hover:shadow-blue-500/20 transition-all duration-300 cursor-pointer transform hover:-translate-y-1">
						🔧 Infrastructure Support
					</span>
				</div>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/role-it-support/projects" class="button_primary text-lg font-bold px-8 py-3">
						View IT Projects
					</a>
					<a href="/portfolio/contact" class="button_secondary text-lg font-bold px-8 py-3">
						Contact Me
					</a>
				</div>
			</div>
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20">
				<a class="animate-bounce" href="#expertise" aria-label="Scroll to expertise section">
					<svg class="h-8 w-8 text-text-secondary hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
					</svg>
					<span class="sr-only">Scroll to expertise section</span>
				</a>
			</div>
		</section>

		<section id="expertise" class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto max-w-6xl">
				<h2 class="text-4xl md:text-5xl font-bold text-center mb-16 fade-in-scroll">Core IT Support Competencies</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 fade-in-scroll">
					<!-- System Administration -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-blue-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20m0 0l-.75 3M9 20H5m15-5h-3.75M15 5h-3m0 0h-3m3 0V2m0 3H6m0 0h-.75m.75 0l-.75-3M19 11l3-.75m0 0l.75-3M22 11h-3m0 0v3m0-3V8"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">System Administration</h3>
						<p class="text-text-secondary">Windows & Linux server management, user account administration, group policies, and system optimization</p>
					</div>

					<!-- Network Management -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-blue-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Network Management</h3>
						<p class="text-text-secondary">TCP/IP configuration, VPN setup, firewall management, network troubleshooting and optimization</p>
					</div>

					<!-- Technical Support -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-blue-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Technical Support</h3>
						<p class="text-text-secondary">Troubleshooting, remote support, helpdesk operations, and end-user IT training</p>
					</div>

					<!-- Infrastructure -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-blue-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Infrastructure</h3>
						<p class="text-text-secondary">Server deployment, storage management, virtualization, and disaster recovery planning</p>
					</div>

					<!-- Documentation -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-blue-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Documentation</h3>
						<p class="text-text-secondary">Technical guides, procedures, knowledge base creation, and process documentation</p>
					</div>

					<!-- Security -->
					<div class="card p-8 text-center">
						<div class="w-16 h-16 bg-blue-500/20 rounded-lg flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Security & Compliance</h3>
						<p class="text-text-secondary">Access control, security patching, compliance monitoring, and vulnerability management</p>
					</div>
				</div>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8 bg-accent-color">
			<div class="container mx-auto max-w-6xl text-center fade-in-scroll">
				<h2 class="text-4xl font-bold mb-6">Featured IT Support Projects</h2>
				<p class="text-lg text-text-secondary mb-12 max-w-3xl mx-auto">Comprehensive technical documentation and hands-on infrastructure projects showcasing IT support expertise</p>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<a href="/portfolio/projects/pc-setup-guide" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-xs font-bold rounded-full">DOCUMENTATION</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">PC Setup Guide</h3>
						<p class="text-text-secondary mb-4">Complete Windows workstation setup, configuration, and optimization procedures</p>
						<span class="inline-flex items-center gap-2 text-blue-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>

					<a href="/portfolio/projects/windows-troubleshooting-guide" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-xs font-bold rounded-full">DOCUMENTATION</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">Windows Troubleshooting</h3>
						<p class="text-text-secondary mb-4">Common Windows issues, diagnostic tools, and systematic problem-solving approaches</p>
						<span class="inline-flex items-center gap-2 text-blue-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>

					<a href="/portfolio/projects/network-setup-guide" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-xs font-bold rounded-full">DOCUMENTATION</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">Network Setup & VPN</h3>
						<p class="text-text-secondary mb-4">Network configuration, VPN setup, remote access solutions, and connectivity troubleshooting</p>
						<span class="inline-flex items-center gap-2 text-blue-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>

					<a href="/portfolio/projects/active-directory-guide" class="card p-8 text-left hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
						<div class="flex items-center gap-3 mb-4">
							<span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-xs font-bold rounded-full">DOCUMENTATION</span>
						</div>
						<h3 class="text-2xl font-bold mb-3">Active Directory & Users</h3>
						<p class="text-text-secondary mb-4">AD administration, user management, group policies, and organizational unit setup</p>
						<span class="inline-flex items-center gap-2 text-blue-400 font-semibold">
							Learn More
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</span>
					</a>
				</div>

				<a href="/portfolio/role-it-support/projects" class="button_primary text-lg font-bold px-8 py-3 mt-12">
					View All IT Projects
				</a>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8">
			<div class="container mx-auto max-w-6xl text-center fade-in-scroll">
				<h2 class="text-4xl font-bold mb-6">Technical Expertise</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16">
					<div class="text-left">
						<h3 class="text-2xl font-bold mb-6">Systems & Platforms</h3>
						<div class="space-y-3">
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Windows Server & Workstations</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Linux Administration (Ubuntu, CentOS)</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Active Directory & Group Policies</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>VMware Virtualization</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>DNS, DHCP & Networking</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Backup & Disaster Recovery</span>
							</div>
						</div>
					</div>

					<div class="text-left">
						<h3 class="text-2xl font-bold mb-6">Tools & Technologies</h3>
						<div class="space-y-3">
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Remote Desktop (RDP, SSH)</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Network Monitoring Tools</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>System Configuration Management</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Ticketing & Issue Tracking</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Cloud Platforms (AWS, Azure basics)</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="w-2 h-2 bg-blue-400 rounded-full"></span>
								<span>Security & Compliance Tools</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="py-24 px-4 sm:px-6 lg:px-8 bg-accent-color text-center">
			<div class="container mx-auto max-w-4xl fade-in-scroll">
				<h2 class="text-4xl font-bold mb-6">Ready to Discuss IT Solutions?</h2>
				<p class="text-lg text-text-secondary mb-8">Let's connect and explore how I can contribute to your IT infrastructure and support needs</p>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/portfolio/contact" class="button_primary text-lg font-bold px-8 py-3">
						Get In Touch
					</a>
					<a href="/portfolio/role-it-support/projects" class="button_secondary text-lg font-bold px-8 py-3">
						View All Projects
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	localStorage.setItem('selectedProfile', 'it-support');
</script>

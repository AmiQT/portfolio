---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/it-support/Header.astro";

const project = {
    title: "DayOne Deploy",
    type: "Zero-Touch Provisioning Suite",
    description: "An enterprise-grade laptop provisioning system built during my internship to automate the complete setup cycle of new hire workstations.",
};

const metrics = [
    { label: "Payload Staging", value: "6GB Offline", icon: "📡" },
    { label: "Deployment Time", value: "-75% Reduction", icon: "⚡" },
    { label: "Reliability", value: "Reboot-Resilient", icon: "🔄" },
    { label: "Interface", value: "Spectre.Console", icon: "📺" },
];

const highlights = [
    {
        title: "Offline Network Staging",
        desc: "Designed a custom staging logic that moves massive software payloads to local storage first, preventing failures from network drops during installation.",
    },
    {
        title: "Automated Hostname & Domain Join",
        desc: "Leveraged WMI and PowerShell hooks to automate hostname reassignment and AD domain binding without manual intervention.",
    },
    {
        title: "State-Persistent State Machine",
        desc: "Implemented registry-based state tracking (RunOnce) that allows the deployment to resume exactly where it left off after system reboots.",
    },
];
---

<Layout
    title="DayOne Deploy - Zero-Touch Provisioning | Noor Azami"
    description={project.description}
>
    <Header />
    <main class="pt-16">
        <!-- Back Button -->
        <div class="px-4 sm:px-6 lg:px-8 py-4">
            <a
                href={import.meta.env.BASE_URL + "role-it-support/projects"}
                class="inline-flex items-center gap-2 text-text-secondary hover:text-blue-400 transition-colors group"
            >
                <svg
                    class="w-5 h-5 group-hover:-translate-x-1 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to IT Projects
            </a>
        </div>

        <!-- Hero Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8 animated-gradient overflow-hidden">
            <div class="container mx-auto max-w-4xl text-center relative z-10">
                <div class="inline-block px-4 py-1 bg-blue-500/10 border border-blue-500/30 rounded-full text-sm text-blue-400 mb-6">
                    Zero-Touch Provisioning & Automation
                </div>
                <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white leading-tight">
                    {project.title}
                </h1>
                <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-10">
                    {project.description}
                </p>
                
                <!-- Status Bar -->
                <div class="bg-background-color/60 backdrop-blur-md rounded-2xl border border-blue-500/20 p-6 shadow-xl max-w-3xl mx-auto">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                        {metrics.map(metric => (
                            <div class="text-center">
                                <div class="text-2xl mb-1">{metric.icon}</div>
                                <div class="text-xs text-text-secondary uppercase tracking-widest mb-1">{metric.label}</div>
                                <div class="text-lg font-bold text-blue-400">{metric.value}</div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- Project Details -->
        <section class="py-20 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto max-w-5xl">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-24">
                    <div>
                        <h2 class="text-3xl font-bold mb-6 border-l-4 border-blue-500 pl-6">Support Optimization</h2>
                        <div class="space-y-6">
                            {highlights.map(item => (
                                <div class="flex gap-4">
                                    <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 shrink-0"></div>
                                    <div>
                                        <h3 class="font-bold text-lg mb-1">{item.title}</h3>
                                        <p class="text-text-secondary leading-relaxed">{item.desc}</p>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                    <div class="relative">
                         <div class="absolute -inset-4 bg-blue-500/10 blur-2xl rounded-full"></div>
                         <div class="relative bg-accent-color border border-blue-500/20 rounded-2xl p-8 shadow-2xl">
                             <div class="flex items-center gap-2 mb-6 text-blue-400">
                                 <div class="w-3 h-3 rounded-full bg-green-500 animate-pulse"></div>
                                 <span class="text-sm font-bold tracking-widest uppercase">Deployment Terminal</span>
                             </div>
                             <div class="space-y-2 font-mono text-xs">
                                 <div class="text-text-secondary italic">// DayOne Deploy v1.0</div>
                                 <div class="text-blue-400">[ACTION] Staging Payload (6.2 GB)...</div>
                                 <div class="text-white">Progress: [████████░░] 82%</div>
                                 <div class="text-white">State: INSTALL_SOFTWARE_B_PKG</div>
                                 <div class="text-yellow-400">[SYSTEM] Reboot Scheduled by state machine</div>
                                 <div class="pt-4 border-t border-white/10 text-green-400">>> Success: Node Joined to Domain</div>
                             </div>
                         </div>
                    </div>
                </div>

                <div class="bg-accent-color rounded-2xl p-10 border border-blue-500/20 text-center">
                    <h2 class="text-2xl font-bold mb-4">Enterprise Scaling</h2>
                    <p class="text-text-secondary max-w-2xl mx-auto mb-8">
                        Built using .NET 10 and C# 13, this tool provides a self-contained, high-performance solution for IT support teams to deploy workstations at scale without manual overhead.
                    </p>
                    <div class="flex flex-wrap justify-center gap-4">
                        <span class="px-4 py-2 bg-background-color rounded-lg border border-white/5 text-sm">C# 13 / .NET 10</span>
                        <span class="px-4 py-2 bg-background-color rounded-lg border border-white/5 text-sm">WinForms</span>
                        <span class="px-4 py-2 bg-background-color rounded-lg border border-white/5 text-sm">Spectre.Console</span>
                        <span class="px-4 py-2 bg-background-color rounded-lg border border-white/5 text-sm">WMI Automation</span>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .animated-gradient {
        background: linear-gradient(-45deg, #0f172a, #010409, #1e1b4b, #010409);
        background-size: 400% 400%;
        animation: gradient 15s ease infinite;
    }

    @keyframes gradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
</style>

---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/it-support/Header.astro";

const project = {
    title: "Enterprise IT Asset Automation",
    subtitle: "Efficiency & Compliance Suite",
    description: "A robust Python-based automation suite designed to streamline IT hardware auditing, utilizing logic blocks for targeted employee notifications and active data self-cleaning.",
    tech: ["Python", "Excel Automation", "Outlook Integration"],
    impact: [
        "Reduced manual asset tracking time by up to 90%",
        "Streamlined compliance for hardware verification",
        "Eliminated human-error in tracking 200+ employees"
    ]
};
---

<Layout
    title="IT Asset Automation - IT Support | Noor Azami"
    description={project.description}
>
    <Header />
    <main class="pt-20 bg-slate-950 min-h-screen text-slate-200">
        <!-- Breadcrumbs -->
        <div class="max-w-6xl mx-auto px-4 py-4">
            <a href={import.meta.env.BASE_URL + "role-it-support/projects"} class="text-cyan-400 hover:text-cyan-300 flex items-center gap-2 text-sm transition-colors">
                <span>←</span> Back to Projects
            </a>
        </div>

        <!-- Hero Section -->
        <section class="py-16 px-4">
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-400 text-sm font-semibold mb-6 uppercase tracking-widest">Case Study: Automation</span>
                    <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white tracking-tight">
                        {project.title}
                    </h1>
                    <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed italic">
                        "{project.subtitle}"
                    </p>
                </div>

                <!-- Stats/Impact Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
                    <div class="bg-slate-900/50 border border-slate-800 p-8 rounded-2xl shadow-xl">
                        <h2 class="text-2xl font-bold mb-6 text-cyan-400 flex items-center gap-3">
                            <span class="bg-cyan-500/20 p-2 rounded-lg text-lg">🚀</span> Business Impact
                        </h2>
                        <ul class="space-y-4">
                            {project.impact.map(item => (
                                <li class="flex items-start gap-3">
                                    <span class="text-cyan-500 mt-1">✓</span>
                                    <span class="text-slate-300">{item}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="bg-slate-900/50 border border-slate-800 p-8 rounded-2xl shadow-xl">
                        <h2 class="text-2xl font-bold mb-6 text-blue-400 flex items-center gap-3">
                            <span class="bg-blue-500/20 p-2 rounded-lg text-lg">🛠️</span> Core Capabilities
                        </h2>
                        <div class="space-y-6">
                            <div>
                                <h3 class="font-bold text-white mb-2">Smart Rate Limiting</h3>
                                <p class="text-sm text-slate-400">Controlled batch processing to ensure SMTP stability across the enterprise network.</p>
                            </div>
                            <div>
                                <h3 class="font-bold text-white mb-2">Data Sanitization</h3>
                                <p class="text-sm text-slate-400">Automatic cleaning of processed entries to eliminate duplicate notifications.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Detailed Logic -->
                <div class="prose prose-invert max-w-none">
                    <h2 class="text-3xl font-bold mb-8 text-white">Operational Excellence</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                        <div>
                            <h3 class="text-xl font-bold text-cyan-300 mb-4">1. Automated Ingestion</h3>
                            <p class="text-slate-400 leading-relaxed">
                                The script processes raw inventory data directly from the system portal, converting legacy Excel formats into high-speed CSV datasets for real-time auditing.
                            </p>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-blue-300 mb-4">2. Audit Logging</h3>
                            <p class="text-slate-400 leading-relaxed">
                                Full accountability via synchronous logging. Every successful alert and potential error is recorded for management review and compliance verification.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mt-20 pt-10 border-t border-slate-800 text-center">
                   <p class="text-slate-500 mb-8 font-mono text-sm underline decoration-cyan-500/30 underline-offset-8">Status: Fully Operational</p>
                    <a href="https://github.com/AmiQT/it-asset-automation" target="_blank" class="inline-flex items-center gap-3 px-8 py-4 bg-cyan-600 hover:bg-cyan-500 text-white rounded-full font-bold transition-all shadow-lg shadow-cyan-900/20">
                        View Technical Docs on GitHub
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>

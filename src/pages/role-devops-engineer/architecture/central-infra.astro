---
import Layout from "../../../layouts/Layout.astro";
import { profile } from "../../../data/devops-engineer.ts";

const baseUrl = import.meta.env.BASE_URL;
const architectureFlow = [
    "IaC: Terraform (4-layer isolation strategy: Cluster, Platform, Apps, Workloads)",
    "Orchestration: k3d local cluster (1 Server, 2 Agents)",
    "Networking: NGINX Ingress Controller via Helm",
    "Observability: Kube-Prometheus-Stack (Prometheus + Grafana)",
    "Security: RBAC with custom Roles & ServiceAccounts",
    "Runtime: Docker Container Runtime (k3s context)"
];

const infraHighlights = [
    "Zero-touch local K8s environment provisioning",
    "Modular Terraform modules for scalability",
    "Comprehensive monitoring dashboard in Grafana",
    "Standardized ingress management with Helm",
    "Isolated namespaces for secure workload deployment"
];
---

<Layout
    title={`${profile.name} - Central-Infra Architecture`}
    description="DevOps architecture breakdown for the Central-Infra Kubernetes sandbox."
    canonical="/role-devops-engineer/architecture/central-infra/"
>
    <main class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900 text-green-400">
        <section class="py-20 px-4 sm:px-6 lg:px-8">
            <div class="max-w-5xl mx-auto">
                <div class="bg-gray-950 border-2 border-green-500/30 rounded-lg shadow-2xl shadow-green-500/20 overflow-hidden">
                    <div class="bg-gray-800 px-4 py-2 flex items-center gap-2 border-b border-green-500/30">
                        <div class="flex gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        </div>
                        <span class="text-gray-400 text-sm ml-4 font-mono">ami@devops:~/architecture$</span>
                    </div>

                    <div class="p-6 sm:p-8 font-mono">
                        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
                            Central-Infra K8s Sandbox Architecture
                        </h1>
                        <p class="text-gray-300 mb-8">
                            A production-simulated Kubernetes infrastructure provisioned entirely through code, focusing on observability and traffic routing.
                        </p>

                        <div class="bg-black/50 border border-green-500/20 rounded-lg p-5 mb-8">
                            <h2 class="text-xl text-white mb-4">Infrastructure Layers</h2>
                            <ol class="space-y-2 text-gray-300">
                                {architectureFlow.map((step, index) => (
                                    <li class="flex items-start gap-3">
                                        <span class="text-green-400">{index + 1}.</span>
                                        <span>{step}</span>
                                    </li>
                                ))}
                            </ol>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                            {infraHighlights.map((item) => (
                                <div class="bg-gray-900 border border-green-500/30 rounded-lg p-4 text-gray-300">
                                    <div class="flex items-start gap-3">
                                        <svg class="w-4 h-4 text-green-400 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>{item}</span>
                                    </div>
                                </div>
                            ))}
                        </div>

                        <div class="flex flex-wrap gap-3">
                            <a
                                href="https://github.com/AmiQT/layer4-workloads"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="px-5 py-2 bg-gray-900 shadow-lg hover:shadow-green-500/10 hover:bg-gray-800 text-green-400 border border-green-500/50 font-semibold rounded flex items-center gap-2 transition-all"
                            >
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                                View Source Code
                            </a>
                            <a
                                href={baseUrl + "role-devops-engineer/"}
                                class="px-5 py-2 bg-gray-800 hover:bg-gray-700 text-green-400 border border-green-500/50 font-semibold rounded transition-all"
                            >
                                Back to DevOps Home
                            </a>
                            <a
                                href={baseUrl + "role-devops-engineer/experience"}
                                class="px-5 py-2 bg-green-500 hover:bg-green-600 text-black font-semibold rounded transition-all"
                            >
                                View Experience
                            </a>
                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

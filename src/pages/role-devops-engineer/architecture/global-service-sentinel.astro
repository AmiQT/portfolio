---
import Layout from "../../../layouts/Layout.astro";
import { profile } from "../../../data/devops-engineer.ts";

const baseUrl = import.meta.env.BASE_URL;

const architectureFlow = [
    "FastAPI Backend -> Asynchronous Monitoring Engine",
    "Request Layer -> curl_cffi with JA3 Chrome 120 Impersonation",
    "Security Bypassing -> Bypasses Cloudflare & Imperva WAFs",
    "Persistence -> Singleton Session Management for Handshake Optimization",
    "Alerting -> Telegram Bot API with 3-Strike Failure Logic",
    "Infrastructure -> Render Blueprint (YAML based IaC)"
];

const infraHighlights = [
    "Advanced JA3 SSL/TLS Fingerprinting for stealth",
    "High-concurrency monitoring via Python Asyncio",
    "Smart alerting logic to eliminate false positives",
    "Production-ready logging with Loguru structured formatting",
    "Real-time glassmorphism observability dashboard"
];
---

<Layout
    title={`${profile.name} - Global Service Sentinel Architecture`}
    description="SRE architecture breakdown for Global Service Sentinel - High-performance stealth monitoring."
    canonical="/role-devops-engineer/architecture/global-service-sentinel/"
>
    <main class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900 text-blue-400">
        <section class="py-20 px-4 sm:px-6 lg:px-8">
            <div class="max-w-5xl mx-auto">
                <div class="bg-gray-950 border-2 border-blue-500/30 rounded-lg shadow-2xl shadow-blue-500/20 overflow-hidden">
                    <div class="bg-gray-800 px-4 py-2 flex items-center gap-2 border-b border-blue-500/30">
                        <div class="flex gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        </div>
                        <span class="text-gray-400 text-sm ml-4 font-mono">ami@sre-ops:~/architecture$</span>
                    </div>

                    <div class="p-6 sm:p-8 font-mono">
                        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
                            Global Service Sentinel
                        </h1>
                        <p class="text-gray-300 mb-8 max-w-3xl">
                             A high-performance stealth monitoring system engineered to bypass Enterprise-grade WAFs via Advanced TLS Fingerprinting and asynchronous concurrency.
                        </p>

                        <div class="bg-black/50 border border-blue-500/20 rounded-lg p-5 mb-8">
                            <h2 class="text-xl text-white mb-4 flex items-center gap-2">
                                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                </svg>
                                System Architecture Flow
                            </h2>
                            <ol class="space-y-3 text-gray-300">
                                {architectureFlow.map((step, index) => (
                                    <li class="flex items-start gap-4">
                                        <span class="text-blue-500 font-bold">[{index + 1}]</span>
                                        <span>{step}</span>
                                    </li>
                                ))}
                            </ol>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                            {infraHighlights.map((item) => (
                                <div class="bg-gray-900 border border-blue-500/30 rounded-lg p-4 text-gray-300 hover:border-blue-500/60 transition-colors">
                                    <div class="flex items-start gap-3">
                                        <svg class="w-5 h-5 text-blue-400 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                                        </svg>
                                        <span>{item}</span>
                                    </div>
                                </div>
                            ))}
                        </div>

                        <div class="bg-blue-500/5 border border-blue-500/20 rounded-lg p-6 mb-8">
                            <h2 class="text-xl text-white mb-3">The "X-Factor": WAF Bypassing</h2>
                            <p class="text-sm text-gray-400 leading-relaxed mb-4">
                                Most traditional monitoring agents are identified by their distinct TLS/SSL fingerprint, allowing WAFs like Cloudflare to block automated traffic instantly. 
                                <br/><br/>
                                <strong>Global Service Sentinel</strong> mitigates this by using <strong>curl_cffi</strong> to fully impersonate the <strong>Chrome 120</strong> browser networking stack. This ensures the monitor session remains indistinguishable from human traffic, allowing for persistent uptime tracking on high-security targets.
                            </p>
                        </div>

                        <div class="flex flex-wrap gap-3 mt-10">
                            <a
                                href={baseUrl + "role-devops-engineer/"}
                                class="px-6 py-3 bg-gray-800 hover:bg-gray-700 text-blue-400 border border-blue-500/50 font-semibold rounded-lg transition-all"
                            >
                                ← Terminal Home
                            </a>
                            <a
                                href="https://github.com/AmiQT/web-pulse"
                                target="_blank"
                                class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-lg shadow-blue-500/20 transition-all"
                            >
                                Source Code Repo
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

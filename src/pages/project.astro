---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Projects - Noor Azami" description="Browse the projects of Noor Azami, including mobile apps, landing pages, and other software development work.">
    <Header />
    <main class="pt-16">
        <section class="py-24 px-4 sm:px-6 lg:px-8 text-center">
            <div class="container mx-auto fade-in-scroll">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">My Projects</h1>
                <p class="text-lg text-text-secondary max-w-3xl mx-auto">A collection of my work, from mobile apps to command-line tools.</p>
            </div>
        </section>

        <section class="pb-24 px-4 sm:px-6 lg:px-8">
            <div class="container mx-auto">
                <!-- Filter Buttons -->
                <div class="flex flex-col items-center mb-12 fade-in-scroll">
                    <div class="flex justify-center flex-wrap gap-4 mb-4">
                        <button class="filter-button active" data-filter="all">All</button>
                        <button class="filter-button" data-filter="web-development">Web Development</button>
                        <button class="filter-button" data-filter="mobile">Mobile App</button>
                        <button class="filter-button" data-filter="documentation">IT Documentation</button>
                        <button class="filter-button" data-filter="c++">C++</button>
                    </div>
                    <div class="filter-counter">Showing 10 projects</div>
                </div>

                <!-- Project Grid -->
                <div class="projects-grid project-grid">
                    <!-- Project: StyleHub -->
                    <div class="project-card fade-in-scroll" data-category="web-development">
                        <div class="project-image-container">
                            <div class="w-full h-full bg-gradient-to-br from-pink-500/20 to-purple-500/20 rounded-lg flex items-center justify-center border border-pink-500/30">
                                <div class="text-center">
                                    <div class="w-16 h-16 bg-pink-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                                        </svg>
                                    </div>
                                    <h4 class="text-sm font-bold text-pink-400">StyleHub</h4>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">StyleHub - Fashion E-Commerce Platform</h3>
                                <div class="project-badges">
                                    <span class="project-badge web-development">Web Development</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">React</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Node.js</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">PostgreSQL</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A modern, responsive e-commerce website built with React, Node.js, and PostgreSQL. Features a complete shopping experience with user authentication, product management, shopping cart, and order processing.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/stylehub"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Rumah Tenang -->
                    <div class="project-card fade-in-scroll" data-category="web-development">
                        <div class="project-image-container">
                            <img src={import.meta.env.BASE_URL + "assets/rumah_tenang.webp"} alt="Rumah Tenang Project" class="w-full h-full object-contain rounded-lg" width="368" height="178" loading="lazy">
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Rumah Tenang - Your Authentic Malaysian Escape</h3>
                                <div class="project-badges">
                                    <span class="project-badge web-development">Web Development</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">HTML</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">CSS</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">JS</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A responsive landing page for a Malaysian homestay business targeting foreign tourists and vacationers. Features an interactive image gallery showcasing local attractions and a contact form for booking inquiries.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/rumah-tenang"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Nasi Lemak Burger -->
                    <div class="project-card fade-in-scroll" data-category="web-development">
                        <div class="project-image-container">
                            <img src={import.meta.env.BASE_URL + "assets/burger.webp"} alt="Nasi Lemak Burger Project" class="w-full h-full object-contain rounded-lg" width="354" height="179" loading="lazy">
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Nasi Lemak Burger</h3>
                                <div class="project-badges">
                                    <span class="project-badge web-development">Web Development</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">HTML</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">CSS</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">JS</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A dynamic promotional landing page featuring a countdown timer that resets on each visit, creating urgency for limited-time food promotions. Designed to drive immediate customer action and boost conversions.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/nasi-lemak-burger"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Healthy Food App -->
                    <div class="project-card fade-in-scroll" data-category="mobile">
                        <div class="project-image-container">
                            <div class="mobile-mockup">
                                <div class="text-center text-xs font-bold text-white mb-2">Healthy Food App</div>
                                <div class="flex-grow bg-gray-700 rounded-lg p-2 text-xs text-gray-300 overflow-hidden">
                                    <p class="font-semibold mb-1">✨ Features</p>
                                    <ul class="list-disc list-inside text-gray-400">
                                        <li>Meal Discovery</li>
                                        <li>Nutritional Tracking</li>
                                        <li>Shopping Cart</li>
                                        <li>Offline Access</li>
                                    </ul>
                                </div>
                                <div class="flex justify-center items-center mt-2">
                                    <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Healthy Food App</h3>
                                <div class="project-badges">
                                    <span class="project-badge mobile">Mobile App</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-600/20 text-blue-400 border border-blue-600/30 rounded">Flutter</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">Dart</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30 rounded">Firebase</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A comprehensive mobile app for healthy meal planning featuring recipe generation, local shop delivery integration, and premium subscription plans for personalized diet meal plans.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/healthy-food-app"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Hotel Management System -->
                    <div class="project-card fade-in-scroll" data-category="c++">
                        <div class="project-image-container">
                            <div class="terminal-mockup">
                                <div class="flex items-center pb-1 mb-1 border-b border-gray-700">
                                    <div class="w-3 h-3 bg-red-500 rounded-full mr-1.5"></div>
                                    <div class="w-3 h-3 bg-yellow-500 rounded-full mr-1.5"></div>
                                    <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                                </div>
                                <div class="flex-grow overflow-hidden">
                                    <p class="text-gray-400">> g++ main.cpp -o hotel_manager</p>
                                    <p class="text-gray-400">> ./hotel_manager</p>
                                    <p>Hotel Management System</p>
                                    <p>1. Add Room</p>
                                    <p>2. Book Room</p>
                                    <p>3. Checkout Room</p>
                                    <p class="text-green-400 animate-pulse">> Enter choice: _</p>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Hotel Management System</h3>
                                <div class="project-badges">
                                    <span class="project-badge cpp">C++</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-700/20 text-blue-400 border border-blue-700/30 rounded">C++</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-600/20 text-purple-400 border border-purple-600/30 rounded">OOP</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-gray-500/20 text-gray-400 border border-gray-500/30 rounded">CLI</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">A complete command-line hotel management system implementing all essential booking flow operations using Object-Oriented Programming principles for robust and scalable architecture.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/hotel-management-system"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View Project
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Windows PC Setup Guide -->
                    <div class="project-card fade-in-scroll" data-category="documentation">
                        <div class="project-image-container">
                            <div class="w-full h-full bg-gradient-to-br from-blue-500/20 to-indigo-500/20 rounded-lg flex items-center justify-center border border-blue-500/30">
                                <div class="text-center">
                                    <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                        </svg>
                                    </div>
                                    <h4 class="text-sm font-bold text-blue-400">PC Setup Guide</h4>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Windows PC Setup & Optimization Guide</h3>
                                <div class="project-badges">
                                    <span class="project-badge documentation">IT Documentation</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-indigo-500/20 text-indigo-400 border border-indigo-500/30 rounded">Windows 10/11</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">Setup</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">Security</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">Comprehensive step-by-step guide for setting up and optimizing Windows 10/11 systems. Covers installation, security hardening, performance optimization, and backup strategies.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/pc-setup-guide"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    Read Guide
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Troubleshooting Guide -->
                    <div class="project-card fade-in-scroll" data-category="documentation">
                        <div class="project-image-container">
                            <div class="w-full h-full bg-gradient-to-br from-orange-500/20 to-red-500/20 rounded-lg flex items-center justify-center border border-orange-500/30">
                                <div class="text-center">
                                    <div class="w-16 h-16 bg-orange-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m6-4a2 2 0 11-4 0 2 2 0 014 0zM9 9a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                        </svg>
                                    </div>
                                    <h4 class="text-sm font-bold text-orange-400">Troubleshooting</h4>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Common IT Issues Troubleshooting</h3>
                                <div class="project-badges">
                                    <span class="project-badge documentation">IT Documentation</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-orange-500/20 text-orange-400 border border-orange-500/30 rounded">WiFi</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-red-500/20 text-red-400 border border-red-500/30 rounded">Printer</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded">Performance</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">Practical troubleshooting solutions for common IT issues including WiFi connectivity, printer problems, application crashes, disk space, and performance issues - covering 80% of support tickets.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/windows-troubleshooting-guide"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    Read Guide
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Network Setup Guide -->
                    <div class="project-card fade-in-scroll" data-category="documentation">
                        <div class="project-image-container">
                            <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-cyan-500/20 rounded-lg flex items-center justify-center border border-teal-500/30">
                                <div class="text-center">
                                    <div class="w-16 h-16 bg-teal-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                    </div>
                                    <h4 class="text-sm font-bold text-teal-400">Network Setup</h4>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Network & Remote Access Setup</h3>
                                <div class="project-badges">
                                    <span class="project-badge documentation">IT Documentation</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-teal-500/20 text-teal-400 border border-teal-500/30 rounded">Network</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-cyan-500/20 text-cyan-400 border border-cyan-500/30 rounded">VPN</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">RDP</span>
                                    </div>
                                </div>
                            </div>
                            <p class="project-description mb-4">Complete guide for network configuration, VPN setup, remote desktop access, and connectivity troubleshooting. Includes network basics, IP addressing, and diagnostic commands.</p>
                            <div class="project-actions">
                                <a href={import.meta.env.BASE_URL + "projects/network-setup-guide"} class="project-action-button primary">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    Read Guide
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Project: Active Directory & User Management -->
                    <div class="project-card fade-in-scroll" data-category="documentation">
                        <div class="project-image-container">
                            <div class="w-full h-full bg-gradient-to-br from-purple-500/20 to-indigo-500/20 rounded-lg flex items-center justify-center border border-purple-500/30">
                                <div class="text-center">
                                    <div class="w-16 h-16 bg-purple-500/20 rounded-full flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                                        </svg>
                                    </div>
                                    <h4 class="text-sm font-bold text-purple-400">Active Directory</h4>
                                </div>
                            </div>
                        </div>
                        <div class="project-card-content">
                            <div class="project-header">
                                <h3 class="project-title">Active Directory & User Management</h3>
                                <div class="project-badges">
                                    <span class="project-badge documentation">IT Documentation</span>
                                    <div class="skills-tags">
                                        <span class="px-2 py-1 text-xs font-semibold bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded">AD</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-indigo-500/20 text-indigo-400 border border-indigo-500/30 rounded">GPO</span>
                                        <span class="px-2 py-1 text-xs font-semibold bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded">Permissions</span>
                                    </div>
                                </div>

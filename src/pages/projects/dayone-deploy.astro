---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/shared/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const project = {
    title: "DayOne Deploy",
    type: "Enterprise Automation Suite",
    category: "it",
    status: "intern",
    description: "C# (.NET 10) automation suite for zero-touch laptop provisioning at DayOne internship. Features offline network staging, resilient orchestration via RunOnce, and real-time observability with Spectre.Console.",
    tech: ["C# 13", ".NET 10", "PowerShell", "WMI", "Spectre.Console", "Windows Forms"],
    github: "https://github.com/AmiQT/dayone-deploy",
};

const features = [
    {
        icon: "cloud",
        title: "Offline Network Staging",
        desc: "Automates staging of 6GB+ software payload from network share to local SSD to prevent network-drop failures.",
        highlight: true,
    },
    {
        icon: "settings",
        title: "Resilient Orchestration",
        desc: "Uses Windows RunOnce registry keys to survive forced system reboots and maintain deployment state.",
    },
    {
        icon: "antenna",
        title: "Interactive Observability",
        desc: "Real-time metrics, live progress spinners, and automated Toast notifications for deployment tracking.",
    },
    {
        icon: "shield",
        title: "Security & Credentialing",
        desc: "Dynamic isolation of sensitive credentials locally via DotNetEnv and enforced UAC Administrator privileges.",
    },
];

const architecture = [
    { step: "1", title: "Network Staging", desc: "Local SSD Payload" },
    { step: "2", title: "Domain Join", desc: "WMI/PowerShell" },
    { step: "3", title: "Software Install", desc: "Idempotent Layers" },
    { step: "4", title: "State Persistence", desc: "RunOnce Registry" },
    { step: "5", title: "Observability", desc: "Spectre.Console" },
];
---

<Layout
    title="DayOne Deploy | Enterprise Automation | Noor Azami"
    description={project.description}
    canonical="/projects/dayone-deploy"
>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <a href={baseUrl + "projects"} class="hover:text-white transition-colors">projects</a>
            <span>/</span>
            <span class="text-[#e6edf3]">dayone-deploy</span>
        </div>

        <!-- Header Card -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8 mb-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-6">
                <span class="text-[#8b949e] shrink-0"><Icon name="monitor" class="w-10 h-10" /></span>
                <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <h1 class="text-2xl font-bold text-white">{project.title}</h1>
                        <span class="flex items-center gap-1 text-xs text-amber-400 bg-amber-500/10 border border-amber-500/25 px-2 py-0.5 rounded-full font-mono">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                            Intern
                        </span>
                        <span class="text-xs text-amber-400 bg-amber-500/10 border border-amber-500/25 px-2 py-0.5 rounded-full font-mono">IT Support</span>
                    </div>
                    <p class="text-[#8b949e] text-sm font-mono mb-3">{project.type}</p>
                    <p class="text-[#e6edf3] text-sm leading-relaxed">{project.description}</p>
                </div>
            </div>

            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tech.map(t => (
                    <span class="text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d]">{t}</span>
                ))}
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-5 border-t border-[#30363d]">
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="github" class="w-4 h-4" />
                    View on GitHub
                </a>
            </div>
        </div>

        <!-- Features -->
        <div class="mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {features.map(f => (
                    <div class={`bg-[#161b22] border rounded-xl p-5 flex gap-4 ${f.highlight ? "border-amber-500/40" : "border-[#30363d]"}`}>
                        <span class={`shrink-0 mt-0.5 ${f.highlight ? "text-amber-400" : "text-[#8b949e]"}`}>
                            <Icon name={f.icon} class="w-5 h-5" />
                        </span>
                        <div>
                            <h3 class="font-semibold text-[#e6edf3] text-sm mb-1">{f.title}</h3>
                            <p class="text-xs text-[#8b949e] leading-relaxed">{f.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Architecture Flow -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-5">// provisioning_state_machine</h2>
            <div class="flex flex-col md:flex-row items-start md:items-center gap-3">
                {architecture.map((item, idx) => (
                    <>
                        <div class="flex-1 bg-[#0d1117] border border-[#30363d] rounded-lg p-4 text-center min-w-[110px]">
                            <div class="text-xs text-blue-400 font-mono font-bold mb-1">{item.step}.</div>
                            <div class="text-sm font-semibold text-[#e6edf3] mb-0.5">{item.title}</div>
                            <div class="text-[10px] text-[#8b949e] font-mono">{item.desc}</div>
                        </div>
                        {idx < architecture.length - 1 && (
                            <span class="hidden md:block text-[#8b949e] text-lg shrink-0">→</span>
                        )}
                    </>
                ))}
            </div>
        </div>

        <!-- Back -->
        <div class="flex items-center gap-4">
            <a
                href={baseUrl + "projects"}
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-mono rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
            >
                ← Back to Projects
            </a>
        </div>

    </main>
</Layout>

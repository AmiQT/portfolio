---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/shared/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const project = {
    title: "FinTrack Pro",
    type: "Enterprise Payroll & HR Management System",
    category: "dev",
    status: "active",
    description: "Enterprise-grade Payroll & HR Management System built with Spring Boot 3.2 + React 18. Automates EPF (11%/13%), SOCSO, and PCB tax calculations, manages multi-role leave workflows, and generates professional PDF payslips via iText 7. Ships with full CI/CD, 42 Testcontainers-backed integration tests, Prometheus telemetry, and Bucket4j API rate limiting.",
    tech: ["Java 21", "Spring Boot 3.2", "React 18", "PostgreSQL 16", "Redis 7", "JWT", "iText 7", "Docker Compose", "GitHub Actions", "Prometheus", "JUnit 5", "Testcontainers", "Recharts", "Tailwind CSS"],
    github: "https://github.com/AmiQT/fin-track",
};

const features = [
    {
        icon: "server",
        title: "Automated Payroll Engine",
        desc: "Precise EPF (11%/13%), SOCSO, EIS, and PCB tax calculations. Auto-deducts salary for approved unpaid leaves based on working days. Interactive Recharts analytics for monthly trends.",
        highlight: true,
    },
    {
        icon: "monitor",
        title: "Employee Management",
        desc: "Full CRUD for employee records with Role-Based Access Control — distinct dashboards for Admin, HR, and Employee roles. Active/inactive personnel status tracking.",
    },
    {
        icon: "check",
        title: "Leave Workflow",
        desc: "Employees apply for Annual, Medical, or Unpaid leave with real-time balance tracking. HR/Managers approve or reject — rejected requests auto-refund leave balances.",
    },
    {
        icon: "document",
        title: "Digital Payslips & Security",
        desc: "Professional PDF payslips generated on-demand via iText 7. JWT stateless auth with Bucket4j API rate limiting to prevent brute-force attacks.",
    },
    {
        icon: "antenna",
        title: "Observability & CI/CD",
        desc: "GitHub Actions runs all 42 tests (Testcontainers + real PostgreSQL) on every push. Jacoco coverage reports auto-generated. Prometheus metrics at /actuator/prometheus for Grafana.",
    },
    {
        icon: "database",
        title: "Performance Caching",
        desc: "Redis 7 caches dashboard and API responses for high-throughput scenarios. Logback profile-aware logging: dev console + prod rolling files (10MB/file, 1GB retention).",
    },
];

const architecture = [
    { step: "1", title: "React Frontend", desc: "Vite + Tailwind + Recharts" },
    { step: "2", title: "Spring Boot API", desc: "JWT Auth + Rate Limiting" },
    { step: "3", title: "PostgreSQL 16", desc: "Relational data store" },
    { step: "4", title: "Redis 7", desc: "Dashboard cache layer" },
    { step: "5", title: "iText 7", desc: "PDF payslip engine" },
];

const roles = [
    { label: "Admin", color: "blue", desc: "Full system access — employees, payroll, reports" },
    { label: "HR", color: "violet", desc: "Leave approvals, employee management" },
    { label: "Employee", color: "green", desc: "Own leaves, payslips, and profile" },
];
---

<Layout
    title="FinTrack Pro | Payroll & HR System | Noor Azami"
    description={project.description}
    canonical="/projects/fin-track"
>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <a href={baseUrl + "projects"} class="hover:text-white transition-colors">projects</a>
            <span>/</span>
            <span class="text-[#e6edf3]">fin-track</span>
        </div>

        <!-- Header Card -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8 mb-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-6">
                <span class="text-[#8b949e] shrink-0"><Icon name="document" class="w-10 h-10" /></span>
                <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <h1 class="text-2xl font-bold text-white">{project.title}</h1>
                        <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2 py-0.5 rounded-full font-mono">
                            Active
                        </span>
                        <span class="text-xs text-violet-400 bg-violet-500/10 border border-violet-500/25 px-2 py-0.5 rounded-full font-mono">Dev</span>
                        <span class="text-xs text-[#8b949e] bg-[#21262d] border border-[#30363d] px-2 py-0.5 rounded-full font-mono">Completed</span>
                    </div>
                    <p class="text-[#8b949e] text-sm font-mono mb-3">{project.type}</p>
                    <p class="text-[#e6edf3] text-sm leading-relaxed">{project.description}</p>
                </div>
            </div>

            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tech.map(t => (
                    <span class="text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d]">{t}</span>
                ))}
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-5 border-t border-[#30363d]">
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="github" class="w-4 h-4" />
                    GitHub
                </a>
            </div>
        </div>

        <!-- Features -->
        <div class="mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {features.map(f => (
                    <div class={`bg-[#161b22] border rounded-xl p-5 flex gap-4 ${f.highlight ? "border-blue-500/40" : "border-[#30363d]"}`}>
                        <span class={`shrink-0 mt-0.5 ${f.highlight ? "text-blue-400" : "text-[#8b949e]"}`}>
                            <Icon name={f.icon} class="w-5 h-5" />
                        </span>
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <h3 class="font-semibold text-[#e6edf3] text-sm">{f.title}</h3>
                                {f.highlight && <span class="text-[10px] font-mono text-blue-400 bg-blue-500/10 border border-blue-500/25 px-1.5 py-0.5 rounded">Core</span>}
                            </div>
                            <p class="text-xs text-[#8b949e] leading-relaxed">{f.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Architecture Flow -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-5">// system_architecture</h2>
            <div class="flex flex-col md:flex-row items-start md:items-center gap-3">
                {architecture.map((item, idx) => (
                    <>
                        <div class="flex-1 bg-[#0d1117] border border-[#30363d] rounded-lg p-4 text-center min-w-[110px]">
                            <div class="text-xs text-blue-400 font-mono font-bold mb-1">{item.step}.</div>
                            <div class="text-sm font-semibold text-[#e6edf3] mb-0.5">{item.title}</div>
                            <div class="text-[10px] text-[#8b949e] font-mono">{item.desc}</div>
                        </div>
                        {idx < architecture.length - 1 && (
                            <span class="hidden md:block text-[#8b949e] text-lg shrink-0">→</span>
                        )}
                    </>
                ))}
            </div>
        </div>

        <!-- Role-Based Access -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// role_based_access</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {roles.map(r => (
                    <div class="bg-[#0d1117] border border-[#30363d] rounded-lg p-4">
                        <span class={`inline-block text-xs font-mono px-2 py-0.5 rounded-full mb-2 ${
                            r.color === "blue" ? "text-blue-400 bg-blue-500/10 border border-blue-500/25" :
                            r.color === "violet" ? "text-violet-400 bg-violet-500/10 border border-violet-500/25" :
                            "text-green-400 bg-green-500/10 border border-green-500/25"
                        }`}>{r.label}</span>
                        <p class="text-xs text-[#8b949e] leading-relaxed">{r.desc}</p>
                    </div>
                ))}
            </div>
        </div>

        <!-- Back -->
        <div class="flex items-center gap-4">
            <a
                href={baseUrl + "projects"}
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-mono rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
            >
                ← Back to Projects
            </a>
        </div>

    </main>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/shared/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const project = {
    title: "Go-Lumina",
    type: "High-Performance Reverse Proxy",
    category: "devops",
    status: "active",
    description: "High-performance caching reverse proxy engineered in Go (1.26+). Sustains 7,500 RPS and handles 1,000,000 concurrent requests using custom worker-pools and thread-safe LRU caching.",
    tech: ["Go 1.26+", "Docker (Multi-stage)", "LRU Cache", "Singleflight", "Rate Limiting", "UPX"],
    github: "https://github.com/AmiQT/go-lumina",
};

const stats = [
    { label: "Peak RPS", value: "7,500" },
    { label: "Concurrency", value: "1M Req" },
    { label: "Image Size", value: "~15MB" },
    { label: "Build Time", value: "<10s" },
];

const features = [
    {
        icon: "settings",
        title: "Thread-Safe LRU Cache",
        desc: "Custom implementation using hashicorp/golang-lru to reduce backend load by 60%.",
        highlight: true,
    },
    {
        icon: "lightning",
        title: "Request Coalescing",
        desc: "Singleflight integration to prevent cache stampede for high-traffic keys.",
    },
    {
        icon: "kubernetes",
        title: "Worker Pool Architecture",
        desc: "Custom Go worker-pools to optimize CPU usage during high concurrency bursts.",
    },
    {
        icon: "document",
        title: "Docker Optimization",
        desc: "Multi-stage builds with UPX compression for ultra-lean production artifacts.",
    },
];
---

<Layout
    title="Go-Lumina | High-Performance Proxy | Noor Azami"
    description={project.description}
    canonical="/projects/go-lumina"
>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <a href={baseUrl + "projects"} class="hover:text-white transition-colors">projects</a>
            <span>/</span>
            <span class="text-[#e6edf3]">go-lumina</span>
        </div>

        <!-- Header Card -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8 mb-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-6">
                <span class="text-[#8b949e] shrink-0"><Icon name="lightning" class="w-10 h-10" /></span>
                <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <h1 class="text-2xl font-bold text-white">{project.title}</h1>
                        <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2 py-0.5 rounded-full font-mono">
                            Active
                        </span>
                        <span class="text-xs text-blue-400 bg-blue-500/10 border border-blue-500/25 px-2 py-0.5 rounded-full font-mono">DevOps</span>
                    </div>
                    <p class="text-[#8b949e] text-sm font-mono mb-3">{project.type}</p>
                    <p class="text-[#e6edf3] text-sm leading-relaxed">{project.description}</p>
                </div>
            </div>

            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tech.map(t => (
                    <span class="text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d]">{t}</span>
                ))}
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 mb-6">
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="github" class="w-4 h-4" />
                    View on GitHub
                </a>
            </div>

        <!-- Stats Row -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 pt-5 border-t border-[#30363d]">
                {stats.map(s => (
                    <div class="bg-[#0d1117] border border-[#30363d] rounded-lg p-3 text-center">
                        <div class="text-lg font-bold text-white font-mono">{s.value}</div>
                        <div class="text-xs text-[#8b949e] mt-0.5">{s.label}</div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Features -->
        <div class="mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {features.map(f => (
                    <div class={`bg-[#161b22] border rounded-xl p-5 flex gap-4 ${f.highlight ? "border-blue-500/40" : "border-[#30363d]"}`}>
                        <span class={`shrink-0 mt-0.5 ${f.highlight ? "text-blue-400" : "text-[#8b949e]"}`}>
                            <Icon name={f.icon} class="w-5 h-5" />
                        </span>
                        <div>
                            <h3 class="font-semibold text-[#e6edf3] text-sm mb-1">{f.title}</h3>
                            <p class="text-xs text-[#8b949e] leading-relaxed">{f.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Back -->
        <div class="flex items-center gap-4">
            <a
                href={baseUrl + "projects"}
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-mono rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
            >
                ← Back to Projects
            </a>
        </div>

    </main>
</Layout>

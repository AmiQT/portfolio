---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/shared/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const project = {
    title: "Central-Infra",
    type: "Kubernetes Sandbox Architecture",
    category: "devops",
    status: "active",
    description: "Modular, multi-tier k3d cluster simulating production environments. Provisioned via Terraform across 4 layers with NGINX Ingress and Prometheus/Grafana observability stack.",
    tech: ["Kubernetes", "Terraform", "Helm", "k3d", "Prometheus", "Grafana", "NGINX Ingress", "RBAC"],
    github: "https://github.com/AmiQT/layer4-workloads",
};

const features = [
    {
        icon: "kubernetes",
        title: "4-Layer Terraform Isolation",
        desc: "Infrastructure provisioned across 4 isolated layers using Terraform — each layer independently managed for modularity and safe teardown.",
        highlight: true,
    },
    {
        icon: "settings",
        title: "k3d Local Cluster",
        desc: "Lightweight k3d cluster (1 server + 2 agent nodes) simulating a production-grade multi-node Kubernetes environment on local hardware.",
    },
    {
        icon: "globe",
        title: "NGINX Ingress via Helm",
        desc: "Ingress controller deployed via Helm chart, enabling path-based and host-based routing across services within the cluster.",
    },
    {
        icon: "antenna",
        title: "Full Observability Stack",
        desc: "Kube-Prometheus-Stack deployed for metrics collection and Grafana dashboards — real-time visibility into node health, pod status, and workload performance.",
    },
    {
        icon: "shield",
        title: "Zero-Trust Security Baseline",
        desc: "RBAC policies, isolated namespaces per workload, and dedicated ServiceAccounts enforcing least-privilege access across the cluster.",
    },
    {
        icon: "lightning",
        title: "Production Simulation",
        desc: "Mirrors real production cluster behaviour — rolling updates, health probes, resource limits, and namespace-level isolation.",
    },
];

const architecture = [
    { step: "1", title: "Layer 0", desc: "Cluster Bootstrap (k3d)" },
    { step: "2", title: "Layer 1", desc: "Networking (NGINX + Helm)" },
    { step: "3", title: "Layer 2", desc: "Workloads & Services" },
    { step: "4", title: "Layer 3", desc: "Observability (Prometheus + Grafana)" },
    { step: "5", title: "Layer 4", desc: "Security (RBAC + ServiceAccounts)" },
];
---

<Layout
    title="Central-Infra | Kubernetes Sandbox | Noor Azami"
    description={project.description}
    canonical="/projects/central-infra"
>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <a href={baseUrl + "projects"} class="hover:text-white transition-colors">projects</a>
            <span>/</span>
            <span class="text-[#e6edf3]">central-infra</span>
        </div>

        <!-- Header Card -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8 mb-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-6">
                <span class="text-[#8b949e] shrink-0"><Icon name="kubernetes" class="w-10 h-10" /></span>
                <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <h1 class="text-2xl font-bold text-white">{project.title}</h1>
                        <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2 py-0.5 rounded-full font-mono">
                            Active
                        </span>
                        <span class="text-xs text-blue-400 bg-blue-500/10 border border-blue-500/25 px-2 py-0.5 rounded-full font-mono">DevOps</span>
                    </div>
                    <p class="text-[#8b949e] text-sm font-mono mb-3">{project.type}</p>
                    <p class="text-[#e6edf3] text-sm leading-relaxed">{project.description}</p>
                </div>
            </div>

            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tech.map(t => (
                    <span class="text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d]">{t}</span>
                ))}
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-5 border-t border-[#30363d]">
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="github" class="w-4 h-4" />
                    View on GitHub
                </a>
            </div>
        </div>

        <!-- Features -->
        <div class="mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {features.map(f => (
                    <div class={`bg-[#161b22] border rounded-xl p-5 flex gap-4 ${f.highlight ? "border-blue-500/40" : "border-[#30363d]"}`}>
                        <span class={`shrink-0 mt-0.5 ${f.highlight ? "text-blue-400" : "text-[#8b949e]"}`}>
                            <Icon name={f.icon} class="w-5 h-5" />
                        </span>
                        <div>
                            <h3 class="font-semibold text-[#e6edf3] text-sm mb-1">{f.title}</h3>
                            <p class="text-xs text-[#8b949e] leading-relaxed">{f.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Architecture Flow -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-5">// cluster_layer_architecture</h2>
            <div class="flex flex-col md:flex-row items-start md:items-center gap-3">
                {architecture.map((item, idx) => (
                    <>
                        <div class="flex-1 bg-[#0d1117] border border-[#30363d] rounded-lg p-4 text-center min-w-[110px]">
                            <div class="text-xs text-blue-400 font-mono font-bold mb-1">{item.step}.</div>
                            <div class="text-sm font-semibold text-[#e6edf3] mb-0.5">{item.title}</div>
                            <div class="text-[10px] text-[#8b949e] font-mono">{item.desc}</div>
                        </div>
                        {idx < architecture.length - 1 && (
                            <span class="hidden md:block text-[#8b949e] text-lg shrink-0">→</span>
                        )}
                    </>
                ))}
            </div>
        </div>

        <!-- Back -->
        <div class="flex items-center gap-4">
            <a
                href={baseUrl + "projects"}
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-mono rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
            >
                ← Back to Projects
            </a>
        </div>

    </main>
</Layout>

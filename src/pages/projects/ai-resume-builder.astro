---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/shared/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const project = {
    title: "AI Resume Builder",
    type: "Full-Stack SaaS",
    category: "dev",
    status: "active",
    description: "AI-powered resume builder using Gemini to optimize resumes based on job descriptions. Features professional templates, PDF/Word export, and ATS optimization.",
    tech: ["React 18", "FastAPI", "Supabase", "Gemini AI", "PostgreSQL"],
    github: "https://github.com/AmiQT/ai-resume",
    liveUrl: "https://resume-ai-tawny-seven.vercel.app",
    backendUrl: "https://ai-resume-backend-production-f917.up.railway.app/docs",
    image: "assets/resume_ai.png",
};

const features = [
    {
        icon: "cpu",
        title: "AI Optimization",
        desc: "Gemini LLM analyzes job descriptions and rewrites resume bullet points with action-verb optimization.",
        highlight: true,
    },
    {
        icon: "document",
        title: "Multiple Templates",
        desc: "Professional, Modern, and Creative templates for various industries and career levels.",
    },
    {
        icon: "document",
        title: "Export Options",
        desc: "Download as ATS-friendly PDF or Word (.docx) files ready for submission.",
    },
    {
        icon: "check-circle",
        title: "ATS Check",
        desc: "Ensures resumes pass Applicant Tracking Systems with optimum keyword density and formatting.",
    },
];

const plans = [
    { name: "Free", price: "$0", features: ["3 AI generations", "1 saved resume", "Basic template"] },
    { name: "Pro", price: "$9/mo", active: true, features: ["20 AI generations", "5 saved resumes", "All templates"] },
    { name: "Premium", price: "$19/mo", features: ["Unlimited generations", "Unlimited resumes", "Custom templates"] },
];
---

<Layout
    title="AI Resume Builder | Gemini Powered | Noor Azami"
    description={project.description}
    canonical="/projects/ai-resume-builder"
>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <a href={baseUrl + "projects"} class="hover:text-white transition-colors">projects</a>
            <span>/</span>
            <span class="text-[#e6edf3]">ai-resume-builder</span>
        </div>

        <!-- Header Card -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8 mb-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-6">
                <span class="text-[#8b949e] shrink-0"><Icon name="document" class="w-10 h-10" /></span>
                <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <h1 class="text-2xl font-bold text-white">{project.title}</h1>
                        <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2 py-0.5 rounded-full font-mono">
                            Active
                        </span>
                        <span class="text-xs text-violet-400 bg-violet-500/10 border border-violet-500/25 px-2 py-0.5 rounded-full font-mono">Dev</span>
                    </div>
                    <p class="text-[#8b949e] text-sm font-mono mb-3">{project.type}</p>
                    <p class="text-[#e6edf3] text-sm leading-relaxed">{project.description}</p>
                </div>
            </div>

            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tech.map(t => (
                    <span class="text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d]">{t}</span>
                ))}
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-5 border-t border-[#30363d]">
                <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-white text-[#0d1117] text-sm font-semibold rounded-lg hover:bg-[#e6edf3] transition-colors"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                    Live Demo
                </a>
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="github" class="w-4 h-4" />
                    GitHub
                </a>
                <a
                    href={project.backendUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="code" class="w-4 h-4" />
                    API Docs
                </a>
            </div>
        </div>

        <!-- Screenshot -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden mb-8">
            <div class="px-4 py-2 border-b border-[#30363d] flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-[#30363d]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#30363d]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#30363d]"></span>
                <span class="text-xs text-[#8b949e] font-mono ml-2">preview</span>
            </div>
            <img
                src={baseUrl + project.image}
                alt={project.title}
                class="w-full h-auto object-cover"
                loading="lazy"
            />
        </div>

        <!-- Features -->
        <div class="mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {features.map(f => (
                    <div class={`bg-[#161b22] border rounded-xl p-5 flex gap-4 ${f.highlight ? "border-violet-500/40" : "border-[#30363d]"}`}>
                        <span class={`shrink-0 mt-0.5 ${f.highlight ? "text-violet-400" : "text-[#8b949e]"}`}>
                            <Icon name={f.icon} class="w-5 h-5" />
                        </span>
                        <div>
                            <h3 class="font-semibold text-[#e6edf3] text-sm mb-1">{f.title}</h3>
                            <p class="text-xs text-[#8b949e] leading-relaxed">{f.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Pricing -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-5">// pricing_tiers</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {plans.map(plan => (
                    <div class={`bg-[#0d1117] border rounded-xl p-5 flex flex-col ${plan.active ? "border-violet-500/50" : "border-[#30363d]"}`}>
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="font-semibold text-[#e6edf3] text-sm">{plan.name}</h3>
                            {plan.active && <span class="text-[10px] font-mono text-violet-400 bg-violet-500/10 border border-violet-500/25 px-1.5 py-0.5 rounded">Popular</span>}
                        </div>
                        <div class="text-2xl font-bold text-white font-mono mb-4">{plan.price}</div>
                        <ul class="space-y-2 flex-1">
                            {plan.features.map(f => (
                                <li class="flex items-center gap-2 text-xs text-[#8b949e]">
                                    <span class="text-green-400 shrink-0"><Icon name="check-circle" class="w-3 h-3" /></span>
                                    {f}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>

        <!-- Back -->
        <div class="flex items-center gap-4">
            <a
                href={baseUrl + "projects"}
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-mono rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
            >
                ← Back to Projects
            </a>
        </div>

    </main>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import IdeActivityBar from "../../components/software-dev/IdeActivityBar.astro";
import IdeSidebar from "../../components/software-dev/IdeSidebar.astro";
import MobileNav from "../../components/software-dev/MobileNav.astro";
import NotebookCell from "../../components/software-dev/NotebookCell.astro";

const project = {
    title: "Web-Pulse",
    type: "Uptime Monitoring System",
    description:
        "Fast and reliable website monitoring tool using Python/FastAPI. Simulates normal browser traffic to bypass WAFs and delivers real-time Telegram alerts for downtime.",
    githubUrl: "https://github.com/AmiQT/web-pulse",
};

const technologies = [
    { name: "Python 3.12", color: "blue", icon: "🐍" },
    { name: "FastAPI", color: "green", icon: "⚡" },
    { name: "Telegram API", color: "blue", icon: "🤖" },
    { name: "Asyncio", color: "orange", icon: "🔄" },
    { name: "BeautifulSoup4", color: "yellow", icon: "🥣" },
];

const features = [
    {
        title: "Advanced TLS Impersonation",
        icon: "🕵️",
        desc: "Simulates Chrome 120+ browser fingerprints to bypass Cloudflare/Imperva security shields.",
        highlight: true,
    },
    {
        title: "Smart 3-Strike Logic",
        icon: "🎯",
        desc: "Double-checks failures 3 times from different regions before alerting to prevent false spam.",
    },
    {
        title: "Real-time Dashboard",
        icon: "📊",
        desc: "Glassmorphism UI dashboard updating every 3 seconds with live service health status.",
    },
    {
        title: "Asynchronous Engine",
        icon: "🚀",
        desc: "Powered by Python Asyncio, capable of checking 100+ endpoints simultaneously within seconds.",
    },
];

const files = [
    {
        name: "monitor.py",
        active: true,
        icon: "🐍",
        href: import.meta.env.BASE_URL + "projects/web-pulse",
    },
];
---

<Layout
    title="Web-Pulse - Uptime Monitoring | Noor Azami"
    description={project.description}
>
    <div class="flex h-screen bg-white dark:bg-[#0d1117] text-gray-900 dark:text-gray-300 overflow-hidden font-sans transition-colors duration-300">
        <IdeActivityBar />
        <IdeSidebar files={files} />

        <main class="flex-1 flex flex-col min-w-0 bg-white dark:bg-[#0d1117] transition-colors duration-300">
            <!-- Tab Bar -->
            <div class="flex bg-gray-100 dark:bg-[#010409] border-b border-gray-200 dark:border-gray-800">
                <div class="flex items-center gap-2 px-4 py-2 bg-white dark:bg-[#0d1117] border-t-2 border-emerald-500 text-gray-900 dark:text-white text-sm min-w-fit cursor-pointer">
                    <span>🐍</span><span>monitor.py</span><span class="ml-2 text-gray-500 cursor-pointer">×</span>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-4 md:p-8 scroll-smooth">
                <!-- Hero Section -->
                <NotebookCell cellNumber={1} code={`# Async Uptime Checker\nasync def check_health(url):\n    async with session.get(url, impersonate="chrome120") as resp:\n        if resp.status != 200:\n            await alert_manager.notify(f"🚨 {url} is DOWN!")\n        return resp.status`}>
                    <section class="relative flex flex-col items-center justify-center text-center py-12 md:py-16 bg-gradient-to-br from-emerald-900 via-slate-900 to-teal-900 rounded-lg overflow-hidden border border-emerald-500/30 shadow-2xl">
                        <div class="z-10 px-4">
                            <h1 class="text-3xl md:text-4xl font-bold mb-4 text-white drop-shadow-lg">{project.title}</h1>
                            <p class="text-base md:text-lg font-medium mb-6 max-w-2xl mx-auto text-gray-200">{project.description}</p>
                            <div class="flex flex-wrap justify-center gap-2 mb-6">
                                {technologies.map((tech) => (
                                    <span class="px-3 py-1 bg-black/30 backdrop-blur-md border border-white/20 rounded-full text-xs text-white">
                                        {tech.name}
                                    </span>
                                ))}
                            </div>
                            <div class="flex justify-center">
                                <a
                                    href={project.githubUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-medium transition-colors text-sm"
                                >
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                    </svg>
                                    View Source Code
                                </a>
                            </div>
                        </div>
                    </section>
                </NotebookCell>

                <!-- Features Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                    {features.map(f => (
                        <div class="p-5 bg-white dark:bg-[#161b22] border border-gray-200 dark:border-gray-700 rounded-lg">
                            <div class="text-2xl mb-2">{f.icon}</div>
                            <h3 class="font-bold mb-1">{f.title}</h3>
                            <p class="text-sm text-gray-600 dark:text-gray-400">{f.desc}</p>
                        </div>
                    ))}
                </div>

                <!-- Back Button -->
                <div class="mt-8 text-center pb-8">
                    <a href={import.meta.env.BASE_URL + "role-software-developer/projects"} class="inline-flex items-center gap-2 px-6 py-3 bg-gray-100 dark:bg-[#161b22] border border-gray-200 dark:border-gray-700 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:border-emerald-500/50 transition-all">
                        <span>←</span> Back to All Projects
                    </a>
                </div>
            </div>
        </main>
        <MobileNav files={files} />
    </div>
</Layout>

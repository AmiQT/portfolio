---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/shared/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const project = {
    title: "Home Anywhere",
    type: "Open-Source Homestay Booking Platform",
    category: "dev",
    status: "active",
    description: "Self-hostable homestay booking platform you can run for any property portfolio — boutique stays, family villas, hill retreats, city apartments. Bundles a multi-step guest booking flow, admin dashboard with built-in CMS, Stripe deposit payments, Google Calendar sync, and GA4 analytics. One-command Docker deploy.",
    tech: ["Next.js 14", "React 18", "TypeScript", "Laravel 11", "PHP 8.3", "Tailwind CSS v4", "shadcn/ui", "Stripe", "Google Calendar API", "SQLite / MySQL", "Docker Compose", "Jest", "PHPUnit"],
    github: "https://github.com/AmiQT/home-anywhere",
};

const features = [
    {
        icon: "check",
        title: "Multi-Step Booking Flow",
        desc: "Pick a stay → pick a date → confirm details. Real availability loaded live from the backend — no double bookings, no stale slots.",
        highlight: true,
    },
    {
        icon: "server",
        title: "Stripe Deposit Payments",
        desc: "Guests pay 30% to confirm; balance settled on check-in. Works in demo mode without Stripe keys — no friction for local development.",
    },
    {
        icon: "globe",
        title: "Google Calendar Sync",
        desc: "Every confirmed booking creates a Calendar event via service account. Cancellations remove the event and trigger automatic Stripe refund.",
    },
    {
        icon: "monitor",
        title: "Admin Dashboard & CMS",
        desc: "Full CRUD for stays, slots, and bookings. Edit the hero, stats, testimonials, and CTA banner from the dashboard — no code, no redeploy.",
    },
    {
        icon: "antenna",
        title: "Analytics & Notifications",
        desc: "GA4 funnel events (view_schedule, start_booking, complete_booking) out of the box. Email confirmations via SMTP; WhatsApp stub ready for Twilio.",
    },
    {
        icon: "docker",
        title: "One-Command Docker Deploy",
        desc: "docker compose up boots database, backend, and frontend — auto-generates app key, runs migrations, and seeds demo stays. Both apps ship with Dockerfiles.",
    },
];

const architecture = [
    { step: "1", title: "Next.js 14", desc: "App Router + TypeScript" },
    { step: "2", title: "Laravel 11 API", desc: "PHP 8.3 backend" },
    { step: "3", title: "SQLite / MySQL", desc: "Relational data store" },
    { step: "4", title: "Stripe Checkout", desc: "Deposit + webhooks" },
    { step: "5", title: "Google Calendar", desc: "Booking events sync" },
];

const apiHighlights = [
    { method: "POST", path: "/api/bookings", desc: "Create booking → Stripe checkout URL" },
    { method: "POST", path: "/api/webhooks/stripe", desc: "Payment confirmation + calendar event" },
    { method: "POST", path: "/api/admin/cancel", desc: "Cancel + refund + remove calendar event" },
    { method: "GET/PUT", path: "/api/admin/site-content", desc: "CMS — view/edit homepage copy" },
];
---

<Layout
    title="Home Anywhere | Homestay Booking Platform | Noor Azami"
    description={project.description}
    canonical="/projects/home-anywhere"
>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <a href={baseUrl + "projects"} class="hover:text-white transition-colors">projects</a>
            <span>/</span>
            <span class="text-[#e6edf3]">home-anywhere</span>
        </div>

        <!-- Header Card -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 sm:p-8 mb-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-6">
                <span class="text-[#8b949e] shrink-0"><Icon name="globe" class="w-10 h-10" /></span>
                <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <h1 class="text-2xl font-bold text-white">{project.title}</h1>
                        <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2 py-0.5 rounded-full font-mono">
                            Active
                        </span>
                        <span class="text-xs text-violet-400 bg-violet-500/10 border border-violet-500/25 px-2 py-0.5 rounded-full font-mono">Dev</span>
                        <span class="text-xs text-[#8b949e] bg-[#21262d] border border-[#30363d] px-2 py-0.5 rounded-full font-mono">Open Source · MIT</span>
                    </div>
                    <p class="text-[#8b949e] text-sm font-mono mb-3">{project.type}</p>
                    <p class="text-[#e6edf3] text-sm leading-relaxed">{project.description}</p>
                </div>
            </div>

            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tech.map(t => (
                    <span class="text-xs font-mono px-2.5 py-1 bg-[#21262d] text-[#e6edf3] rounded border border-[#30363d]">{t}</span>
                ))}
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-5 border-t border-[#30363d]">
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-semibold rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
                >
                    <Icon name="github" class="w-4 h-4" />
                    GitHub
                </a>
            </div>
        </div>

        <!-- Features -->
        <div class="mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {features.map(f => (
                    <div class={`bg-[#161b22] border rounded-xl p-5 flex gap-4 ${f.highlight ? "border-blue-500/40" : "border-[#30363d]"}`}>
                        <span class={`shrink-0 mt-0.5 ${f.highlight ? "text-blue-400" : "text-[#8b949e]"}`}>
                            <Icon name={f.icon} class="w-5 h-5" />
                        </span>
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <h3 class="font-semibold text-[#e6edf3] text-sm">{f.title}</h3>
                                {f.highlight && <span class="text-[10px] font-mono text-blue-400 bg-blue-500/10 border border-blue-500/25 px-1.5 py-0.5 rounded">Core</span>}
                            </div>
                            <p class="text-xs text-[#8b949e] leading-relaxed">{f.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Architecture Flow -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-5">// system_architecture</h2>
            <div class="flex flex-col md:flex-row items-start md:items-center gap-3">
                {architecture.map((item, idx) => (
                    <>
                        <div class="flex-1 bg-[#0d1117] border border-[#30363d] rounded-lg p-4 text-center min-w-[110px]">
                            <div class="text-xs text-blue-400 font-mono font-bold mb-1">{item.step}.</div>
                            <div class="text-sm font-semibold text-[#e6edf3] mb-0.5">{item.title}</div>
                            <div class="text-[10px] text-[#8b949e] font-mono">{item.desc}</div>
                        </div>
                        {idx < architecture.length - 1 && (
                            <span class="hidden md:block text-[#8b949e] text-lg shrink-0">→</span>
                        )}
                    </>
                ))}
            </div>
        </div>

        <!-- Key API Endpoints -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// key_api_endpoints</h2>
            <div class="space-y-2">
                {apiHighlights.map(api => (
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 bg-[#0d1117] border border-[#30363d] rounded-lg px-4 py-3">
                        <span class="text-xs font-mono text-blue-400 bg-blue-500/10 border border-blue-500/25 px-2 py-0.5 rounded shrink-0">{api.method}</span>
                        <span class="text-xs font-mono text-[#e6edf3] shrink-0">{api.path}</span>
                        <span class="text-xs text-[#8b949e] sm:ml-auto">{api.desc}</span>
                    </div>
                ))}
            </div>
        </div>

        <!-- Quick Start -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-white font-mono mb-4">// quick_start</h2>
            <p class="text-xs text-[#8b949e] mb-3">One command spins up the full stack — database, backend, and frontend.</p>
            <div class="bg-[#0d1117] border border-[#30363d] rounded-lg p-4 font-mono text-sm">
                <span class="text-green-400">$</span>
                <span class="text-[#e6edf3]"> docker compose up</span>
            </div>
            <div class="mt-3 flex flex-wrap gap-4 text-xs font-mono text-[#8b949e]">
                <span>Guest site → <span class="text-blue-400">localhost:3000</span></span>
                <span>Admin → <span class="text-blue-400">localhost:3000/admin</span></span>
            </div>
        </div>

        <!-- Back -->
        <div class="flex items-center gap-4">
            <a
                href={baseUrl + "projects"}
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#21262d] text-[#e6edf3] text-sm font-mono rounded-lg border border-[#30363d] hover:border-[#8b949e] transition-colors"
            >
                ← Back to Projects
            </a>
        </div>

    </main>
</Layout>

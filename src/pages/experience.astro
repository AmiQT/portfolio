---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/shared/Icon.astro";
import { experiencesData } from "../data/experience";

const baseUrl = import.meta.env.BASE_URL;
const experiences = experiencesData;

---

<Layout
    title="Experience | Muhammad Noor Azami"
    description="Work experience and responsibilities across DevOps, IT Support, and student leadership."
    canonical="/experience"
>
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-[#8b949e] text-sm font-mono mb-8">
            <a href={baseUrl} class="hover:text-white transition-colors">home</a>
            <span>/</span>
            <span class="text-[#e6edf3]">experience</span>
        </div>

        <div class="mb-10">
            <h1 class="text-3xl font-bold text-white mb-2">Experience</h1>
            <p class="text-[#8b949e] text-sm">Work history, responsibilities, and technical contributions.</p>
        </div>

        <!-- Timeline -->
        <div class="relative mb-12">
            <div class="absolute left-5 top-0 bottom-0 w-px bg-[#30363d]"></div>

            <div class="space-y-8">
                {experiences.map((exp, i) => (
                    <div class="relative pl-14">
                        <!-- Timeline dot -->
                        <div class={`absolute left-3 top-3 w-4 h-4 rounded-full border-2 border-[#0d1117] flex items-center justify-center ${i === 0 ? "bg-green-500" : "bg-[#30363d]"}`}>
                            {i === 0 && <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>}
                        </div>

                        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6 hover:border-[#8b949e]/40 transition-colors">
                            <!-- Header -->
                            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
                                <div class="flex items-center gap-3">
                                    <span class="text-[#8b949e]"><Icon name={exp.icon} class="w-6 h-6" /></span>
                                    <div>
                                        <h3 class="font-semibold text-white">{exp.title}</h3>
                                        <p class="text-sm text-[#8b949e] font-mono">{exp.organization}</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2 shrink-0">
                                    {i === 0 && (
                                        <span class="flex items-center text-xs text-green-400 bg-green-500/10 border border-green-500/25 px-2 py-0.5 rounded-full font-mono">
                                            Current
                                        </span>
                                    )}
                                    <span class="text-xs text-[#8b949e] font-mono border border-[#30363d] px-2 py-0.5 rounded bg-[#0d1117]">
                                        {exp.duration}
                                    </span>
                                </div>
                            </div>

                            <!-- Responsibilities -->
                            <div class="space-y-2.5 pl-4 border-l-2 border-[#30363d]">
                                {exp.responsibilities.map(resp => (
                                    <div class="flex gap-2.5 text-sm">
                                        <span class="text-blue-400 shrink-0 mt-0.5">→</span>
                                        <span class="text-[#8b949e] leading-relaxed">{resp}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Education -->
        <div class="bg-[#161b22] border border-[#30363d] rounded-xl p-6">
            <h2 class="text-sm font-semibold text-white mb-4 font-mono">// education</h2>
            <div class="flex items-start gap-4">
                <span class="text-[#8b949e] shrink-0"><Icon name="graduation" class="w-6 h-6" /></span>
                <div>
                    <p class="font-semibold text-[#e6edf3]">Bachelor of Information Technology (IT)</p>
                    <p class="text-sm text-[#8b949e] font-mono">Universiti Tun Hussein Onn Malaysia (UTHM)</p>
                    <p class="text-xs text-[#8b949e] mt-1 border border-[#30363d] inline-block px-2 py-0.5 rounded font-mono">2022 — 2026 (Expected)</p>
                </div>
            </div>
        </div>

    </main>
</Layout>

---
interface Props {
  frontend?: string;
  backend?: string;
  demoLink?: string;
}

const { 
  frontend = "Active", 
  backend = "On-Demand (FinOps Optimized)", 
  demoLink = "/portfolio/contact" 
} = Astro.props;
---

<div class="bg-gray-900/50 border-l-4 border-yellow-500 p-6 my-8 rounded-r-lg shadow-xl backdrop-blur-sm">
    <div class="flex items-start gap-4">
        <div class="text-2xl mt-1">💡</div>
        <div class="flex-1">
            <h4 class="text-white font-bold text-lg mb-2 flex items-center gap-2">
                Architecture Preview Mode
                <span class="text-[10px] bg-yellow-500/20 text-yellow-500 px-2 py-0.5 rounded border border-yellow-500/30 uppercase tracking-tighter">FinOps Active</span>
            </h4>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">
                To maintain a sustainable and cost-efficient cloud infrastructure, the backend services for this project are currently in <strong>"On-Demand"</strong> mode. While the frontend and system architecture are fully available for review, a complete end-to-end live demonstration can be requested or conducted during a technical interview.
            </p>
            
            <div class="flex flex-wrap gap-6 items-center border-t border-white/5 pt-4 mt-2">
                <div class="flex items-center gap-2">
                    <div class="relative flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                    </div>
                    <span class="text-xs font-mono text-gray-300">Frontend: <span class="text-green-400 font-bold">{frontend}</span></span>
                </div>
                
                <div class="flex items-center gap-2">
                    <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
                    <span class="text-xs font-mono text-gray-300">Backend: <span class="text-yellow-400 font-bold">{backend}</span></span>
                </div>
                
                <a 
                    href={demoLink}
                    class="sm:ml-auto text-xs font-bold text-yellow-500 hover:text-black hover:bg-yellow-500 border border-yellow-500/30 px-4 py-2 rounded transition-all active:scale-95 flex items-center gap-2"
                >
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path>
                    </svg>
                    Request Live Demo
                </a>
            </div>
        </div>
    </div>
</div>

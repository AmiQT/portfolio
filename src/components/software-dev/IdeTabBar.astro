---
interface Props {
  tabs?: { name: string; active: boolean; icon: string; onclick?: string }[];
}

const { tabs = [
  { name: 'home-software-developer.ipynb', active: true, icon: '📓', onclick: "document.getElementById('hero').scrollIntoView({behavior: 'smooth'})" },
  { name: 'projects.json', active: false, icon: '📦', onclick: "document.getElementById('projects').scrollIntoView({behavior: 'smooth'})" }
] } = Astro.props;
---
<div class="flex bg-[#010409] border-b border-gray-800 overflow-x-auto scrollbar-hide transition-colors duration-300">
  {tabs.map(tab => (
    <div 
      class={`flex items-center gap-2 px-4 py-2 text-sm min-w-fit cursor-pointer transition-colors duration-300 ${tab.active ? 'bg-[#0d1117] border-t-2 border-orange-500 text-white' : 'text-gray-500 hover:bg-[#161b22]'}`}
      onclick={tab.onclick}
    >
      <span>{tab.icon}</span>
      <span>{tab.name}</span>
      {tab.active && <span class="ml-2 text-gray-500 hover:text-white cursor-pointer text-xs" title="Close Editor">×</span>}
    </div>
  ))}
</div>
